# ════════════════════════════════════════════════════════════════════════════
#  Bot Telegram SoundSystem Hardening — variables d'environnement
#  Aucune valeur reelle ici. Je definis les vraies valeurs dans Coolify
#  (Environment Variables du service bot), jamais dans le repo.
# ════════════════════════════════════════════════════════════════════════════

# ── Telegram (obligatoire) ───────────────────────────────────────────────────
# Token fourni par @BotFather a la creation du bot.
TG_BOT_TOKEN=123456789:AA_token_factice_remplacer

# Allowlist : seuls ces IDs numeriques Telegram peuvent piloter le bot.
# Tout autre expediteur est ignore en silence. Separes par des virgules.
# Pour trouver mon ID : ecrire a @userinfobot.
TG_ALLOWED_IDS=11111111,22222222

# Chat qui recoit les alertes automatiques (sante, signalements).
# Par defaut : le premier ID de l'allowlist.
ALERT_CHAT_ID=11111111

# ── Cible de monitoring (recommande) ─────────────────────────────────────────
SITE_HEALTH_URL=https://soundsystemhardening.fr/api/health
SITE_PUBLIC_URL=https://soundsystemhardening.fr
# Intervalle de sonde sante en secondes.
HEALTH_INTERVAL_SEC=60
# Nombre d'echecs consecutifs avant alerte "site DOWN".
HEALTH_FAIL_THRESHOLD=2

# ── Coolify (pour deploy / restart / stop / maintenance) ──────────────────────
# Depuis le serveur, l'API Coolify est joignable en interne.
# Option A (reseau docker coolify) : http://coolify:8080
# Option B (panel, IP VPN whitelistee) : https://coolify.mondomaine.tld
COOLIFY_BASE_URL=http://coolify:8080
# Token cree dans Coolify : Keys & Tokens / API tokens. Scope minimal.
COOLIFY_API_TOKEN=coolify_token_factice
# UUID de l'application "site" dans Coolify (visible dans l'URL du panel).
COOLIFY_APP_UUID=app-uuid-factice
# Optionnel : webhook de deploiement dedie (alternative simple a l'API pour /deploy).
COOLIFY_DEPLOY_WEBHOOK=

# Nom de la variable d'env que le middleware du site lit pour le mode maintenance.
MAINTENANCE_ENV_KEY=MAINTENANCE_MODE

# ── Liens rapides (boutons URL, optionnel) ────────────────────────────────────
# Bouton masque si la valeur est vide.
COOLIFY_PANEL_URL=
GITHUB_REPO=

# ── Notify interne (push d'alertes depuis le site, optionnel) ─────────────────
# Si defini, le bot ouvre un endpoint HTTP interne /notify protege par HMAC.
# A NE PAS exposer via Traefik : reseau docker interne uniquement.
NOTIFY_SECRET=
NOTIFY_PORT=8099

# ── Airtable (moderation des signalements, optionnel) ─────────────────────────
# IMPORTANT : ce token doit etre scope LECTURE + ECRITURE (le token write-only
# du site ne permet pas de lister les enregistrements a moderer).
AIRTABLE_API_TOKEN=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE=Signalements
# Champ de statut et valeurs utilisees pour le filtrage / la moderation.
AIRTABLE_STATUS_FIELD=Statut
AIRTABLE_STATUS_PENDING=En attente
AIRTABLE_STATUS_APPROVED=Valide
AIRTABLE_STATUS_REJECTED=Rejete

# ── Divers ───────────────────────────────────────────────────────────────────
# Fenetre de rate limit par utilisateur (commandes / minute).
USER_RATE_PER_MIN=20
# Duree de validite d'une demande de confirmation (secondes).
CONFIRM_TTL_SEC=60
LOG_LEVEL=info
