---
import Layout from '../layouts/Layout.astro';
import incidents from '../data/incidents.json';

const totalIncidents = incidents.length;
---

<Layout
  title="Home"
  description="Infrastructure d'autodéfense numérique pour le mouvement free party. Carte de répression, évaluateur de terrain, droits GAV, contre-RIPOST."
>

  <!-- ═══════════════════════════════════════════════════════════
       TICKER PLEINE LARGEUR
  ═══════════════════════════════════════════════════════════ -->
  <div class="ticker-fullbleed">
    <div class="ticker-wrap">
      <div class="ticker-label">ACTUS</div>
      <div class="ticker-mask">
        <div class="ticker-track">
          {[
            '[ JUIN 2026 ] Migration infra vers VPS souverain — Hébergement Suisse, juridiction nLPD',
            '[ VEILLE ] Loi RIPOST votée au Sénat le 26 mai 2026 — industrialisation des AFD et saisies destructives',
            '[ WIKI ] Nouvelle page : Stratégie contre-RIPOST — parades et éléments de langage face aux médias',
            '[ WIKI ] Nouvelle page : Drones thermiques et nasses logistiques — adaptation des infrastructures critiques',
            '[ OPSEC ] Protocoles burners Telegram/Signal via Fragment mis à jour',
            '[ INFRA ] Zéro script tiers — aucun outil de monitoring externe sur les pages wiki',
            '[ DROIT ] Jurisprudences GAV et forçage biométrique mises à jour — mai 2026',
          ].concat([
            '[ JUIN 2026 ] Migration infra vers VPS souverain — Hébergement Suisse, juridiction nLPD',
            '[ VEILLE ] Loi RIPOST votée au Sénat le 26 mai 2026 — industrialisation des AFD et saisies destructives',
            '[ WIKI ] Nouvelle page : Stratégie contre-RIPOST — parades et éléments de langage face aux médias',
            '[ WIKI ] Nouvelle page : Drones thermiques et nasses logistiques — adaptation des infrastructures critiques',
            '[ OPSEC ] Protocoles burners Telegram/Signal via Fragment mis à jour',
            '[ INFRA ] Zéro script tiers — aucun outil de monitoring externe sur les pages wiki',
            '[ DROIT ] Jurisprudences GAV et forçage biométrique mises à jour — mai 2026',
          ]).map(item => (
            <span class="ticker-item">{item}</span>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════════════════ -->
  <section class="hero-section">

    <!-- Headline -->
    <div class="hero-headline">
      <div class="hero-pretitle">// RESISTANCE TOOLKIT · FREE PARTY</div>
      <h1 class="hero-title">
        <span class="hero-title-pre">SOUND<span class="title-green">SYSTEM</span></span>
        <span class="hero-title-main" data-glitch="HARDENING">HARDENING</span>
      </h1>
      <p class="hero-desc">Infrastructure d'autodéfense numérique pour le mouvement free party.</p>
    </div>

    <!-- Stats bar -->
    <div class="hero-stats">
      {[
        { val: String(totalIncidents), label: 'INCIDENTS' },
        { val: '19',  label: 'DEPTS' },
        { val: '60+', label: 'PAGES WIKI' },
        { val: 'EN COURS', label: 'LOI RIPOST' },
      ].map(s => (
        <div class="hero-stat">
          <span class="stat-val">{s.val}</span>
          <span class="stat-label">{s.label}</span>
        </div>
      ))}
    </div>

    <!-- Ligne de contraste -->
    <div class="hero-contrast">
      <div class="contrast-side contrast-side-them">
        <span class="contrast-tag">EUX</span>
        <p class="contrast-text">Ils produisent des arrêtés,<br/>des contrôles et des saisies.</p>
      </div>
      <div class="contrast-vs">
        <div class="contrast-vs-line"></div>
        <span class="contrast-arrow">▸</span>
        <div class="contrast-vs-line"></div>
      </div>
      <div class="contrast-side contrast-side-us">
        <span class="contrast-tag contrast-tag-us">NOUS</span>
        <p class="contrast-text contrast-text-us">Nous avons maintenant les outils<br/>pour déjouer et documenter.</p>
      </div>
    </div>

  </section>

  <!-- ═══════════════════════════════════════════════════════════
       MODULES ACTIFS
  ═══════════════════════════════════════════════════════════ -->
  <section class="modules-section">

    <span class="section-label">MODULES ACTIFS</span>
    <h2 class="modules-h2">Outils et ressources</h2>

    <div class="modules-grid">

      <!-- Ligne 1 : RIPOST + TACTIQUE -->
      <div class="modules-row">
        <a href="/wiki/Strategie-contre-ripost" class="card-neon-tool no-underline group">
          <span class="badge-opsec">RIPOST 2026</span>
          <h3 class="module-title mt-3 group-hover:text-neon-green transition-colors">Contre RIPOST</h3>
          <p class="module-desc">2 ans ferme pour les organisateurs. Décryptage article par article + contre-mesures.</p>
        </a>

        <a href="/wiki/Modus-Operandi" class="card-neon-tool no-underline group">
          <span class="badge-opsec">TACTIQUE</span>
          <h3 class="module-title mt-3 group-hover:text-neon-green transition-colors">Modus Operandi</h3>
          <p class="module-desc">Failles légales et opérationnelles. Là où l'État ne peut structurellement pas intervenir.</p>
        </a>
      </div>

      <!-- Ligne 2 : MAP + RIG-LOCK -->
      <div class="modules-row">
        <a href="/map" class="card-neon-tool no-underline group module-live">
          <div class="module-live-badge">
            <span class="live-dot"></span>
            <span class="live-label">LIVE</span>
          </div>
          <span class="badge-tool">OUTIL INTERACTIF</span>
          <h3 class="module-title mt-3 group-hover:text-neon-green transition-colors">Carte & Terrain</h3>
          <p class="module-desc">
            {totalIncidents} incidents documentés + évaluateur de zone en temps réel.
            Coordonnées dégradées, zéro log.
          </p>
          <div class="card-meta">
            <span>{totalIncidents} INCIDENTS</span>
            <span>·</span>
            <span>1996-2026</span>
            <span>·</span>
            <span>OPEN DATA</span>
          </div>
        </a>

        <a href="/rig-lock" class="card-neon-tool no-underline group">
          <span class="badge-tool">OUTIL LOCAL</span>
          <h3 class="module-title mt-3 group-hover:text-neon-green transition-colors">RIG-LOCK</h3>
          <p class="module-desc">
            Générateur de manifeste de saisie horodaté. PDF vérifiable produit localement, aucune donnée transmise.
          </p>
          <div class="card-meta">
            <span>PDF LOCAL</span>
            <span>·</span>
            <span>ZÉRO SERVEUR</span>
            <span>·</span>
            <span>HORODATÉ</span>
          </div>
        </a>
      </div>

      <!-- OPSEC : pleine largeur -->
      <a href="/wiki/Sécurite-Numerique" class="card-neon-tool no-underline group">
        <div class="module-inner">
          <div class="module-body">
            <div class="module-header">
              <h3 class="module-title group-hover:text-neon-green transition-colors">Sécurité numérique & OPSEC</h3>
              <span class="badge-opsec">OPSEC</span>
            </div>
            <p class="module-desc">Signal, Tor, chiffrement, messagerie sécurisée. Les règles non-négociables avant chaque événement.</p>
          </div>
          <span class="module-arrow group-hover:text-neon-green group-hover:translate-x-1">▸</span>
        </div>
      </a>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       MANIFESTE
  ═══════════════════════════════════════════════════════════ -->
  <section class="manifeste-section">

    <span class="section-label">MODULE 02</span>
    <h2 class="manifeste-h2">Manifeste</h2>
    <p class="manifeste-intro">
      Ce que nous sommes, ce que nous défendons, pourquoi nous ne nous arrêterons pas.
    </p>

    <div class="manifeste-stack">

      <!-- I. D'où nous venons -->
      <details class="manifeste-item group">
        <summary class="manifeste-summary">
          <span class="manifeste-num">I.</span>
          <span class="manifeste-sum-label group-hover:text-neon-green transition-colors">D'où nous venons</span>
          <span class="manifeste-arrow group-open:rotate-90">▸</span>
        </summary>
        <div class="manifeste-body">
          <p>Jamaïque, années 1950. Les sound systems sortent la musique des clubs fermés et la portent dans les rues, les cours, les terrains vagues. Quand on n'a pas les moyens d'entrer, on construit sa propre scène.</p>
          <p>Angleterre, 1994. Le <strong>Criminal Justice Act</strong> criminalise les rassemblements à musique répétitive. Spiral Tribe quitte le pays. La répression n'a pas tué la free party  -  elle l'a exportée sur le continent.</p>
          <p>France, 2001. L'<strong>amendement Mariani</strong> impose la déclaration préalable. La free party entre dans le droit pour mieux être réprimée. France, 2026 : la loi RIPOST ajoute 2 ans de prison. À chaque vague répressive, le mouvement s'est outillé. <strong>Ce wiki aussi.</strong></p>
        </div>
      </details>

      <!-- II. Ce que nous sommes -->
      <details class="manifeste-item group">
        <summary class="manifeste-summary">
          <span class="manifeste-num">II.</span>
          <span class="manifeste-sum-label group-hover:text-neon-green transition-colors">Ce que nous sommes</span>
          <span class="manifeste-arrow group-open:rotate-90">▸</span>
        </summary>
        <div class="manifeste-body">
          <p>Un mouvement de <strong>30 ans</strong>. Des espaces gratuits, sans sélection à l'entrée, sans hiérarchie. Des collectifs qui construisent leur son de leurs propres mains, sur des terrains que personne d'autre ne revendique.</p>
          <p>En 2024, la techno française est inscrite au <strong>patrimoine culturel immatériel de l'UNESCO</strong>. L'État qui la récompense d'un côté la criminalise de l'autre. Le paradoxe est la politique.</p>
          <div class="manifeste-values">
            {[
              { label: 'BIENVEILLANCE', txt: 'Techno+, Freeform - réduction des risques sans jugement', accent: true },
              { label: 'FÉMINISME',     txt: 'Safer space, protocoles contre les violences sexistes', accent: true },
              { label: 'ANTI-FASCISME', txt: "Culture d'accueil inconditionnelle", accent: false },
              { label: 'SOLIDARITÉ',    txt: 'FSJS - défense collective face aux saisies', accent: true },
            ].map(v => (
              <div class={`value-item ${v.accent ? 'value-accent' : 'value-muted'}`}>
                <span class="value-label">{v.label}</span>
                <span class="value-txt">{v.txt}</span>
              </div>
            ))}
          </div>
        </div>
      </details>

      <!-- III. Ce que nous défendons -->
      <details class="manifeste-item group">
        <summary class="manifeste-summary">
          <span class="manifeste-num">III.</span>
          <span class="manifeste-sum-label group-hover:text-neon-green transition-colors">Ce que nous défendons</span>
          <span class="manifeste-arrow group-open:rotate-90">▸</span>
        </summary>
        <div class="manifeste-body">
          {[
            { head: 'La liberté de rassemblement', body: 'Art. 11 CESDH. Ériger une free party en délit est une violation disproportionnée et documentable.' },
            { head: 'La gratuité comme refus du marché', body: "L'État accepte la techno quand elle rapporte de la TVA. Il la réprime quand elle n'en rapporte pas. Ce n'est pas un hasard." },
            { head: "L'autogestion", body: "Le DIY n'est pas une contrainte économique. C'est une philosophie d'autonomie qui ne demande pas de permission." },
            { head: 'La réduction des risques', body: "Le soin n'est jamais une infraction. Techno+ opère là où l'État ne va pas." },
          ].map(item => (
            <div class="defend-item">
              <span class="defend-bullet">◆</span>
              <span><strong>{item.head}</strong>  -  {item.body}</span>
            </div>
          ))}
          <div class="defend-memorial">
            <strong>La mémoire des victimes</strong>  -  Steve Maia Caniço (Nantes, 2019) : mort après une charge de police lors de la Fête de la Musique. Redon 2021 : un participant perd une main lors d'une intervention de gendarmerie. Carhaix 2025 : tirs à balles réelles sur un véhicule. Ces violences ne sont pas des accidents : elles sont le produit d'une politique de force maximale contre des rassemblements non-armés.
          </div>
        </div>
      </details>

      <!-- IV. Ce que nous refusons -->
      <details class="manifeste-item group manifeste-item-critical">
        <summary class="manifeste-summary manifeste-summary-critical">
          <span class="manifeste-num manifeste-num-critical">IV.</span>
          <span class="manifeste-sum-label manifeste-sum-critical group-hover:text-red-400 transition-colors">Ce que nous refusons</span>
          <span class="manifeste-arrow manifeste-arrow-critical group-open:rotate-90">▸</span>
        </summary>
        <div class="manifeste-body manifeste-body-critical">
          {[
            { head: 'La criminalisation de la présence', body: "Danser n'est pas un crime. La loi RIPOST en fait un délit passible de 6 mois de prison. C'est disproportionné et contestable." },
            { head: "L'amalgame avec le crime organisé", body: "Les infractions réelles sont déjà réprimées par le droit commun. La répression des free parties en tant que telles est idéologique, pas sécuritaire." },
            { head: 'La répression préventive', body: "Les arrêtés préfectoraux couvrant des départements entiers avant tout incident sont incompatibles avec l'État de droit et attaquables devant le tribunal administratif." },
            { head: "L'institutionnalisation forcée", body: "On ne règle pas une free party en la déclarant. On ne protège pas la culture en la marchandisant." },
          ].map(item => (
            <div class="refuse-item">
              <span class="refuse-bullet">✕</span>
              <span><strong style="color:#e8e8f0">{item.head}</strong>  -  {item.body}</span>
            </div>
          ))}
        </div>
      </details>

      <!-- V. Ce que nous exigeons -->
      <details class="manifeste-item group">
        <summary class="manifeste-summary">
          <span class="manifeste-num">V.</span>
          <span class="manifeste-sum-label group-hover:text-neon-green transition-colors">Ce que nous exigeons</span>
          <span class="manifeste-arrow group-open:rotate-90">▸</span>
        </summary>
        <div class="manifeste-body">
          {[
            { n:'01', head: "Fin de l'exception répressive", body: "Arrêt des délits de présence et de complicité par le soin. Le personnel de réduction des risques ne peut pas être poursuivi pour exercer sa mission." },
            { n:'02', head: "Abrogation du régime Mariani", body: "25 ans d'existence, 0 preuve d'efficacité sur la sécurité. Il a produit de la clandestinité, pas de la protection." },
            { n:'03', head: "Fin des interdictions massives", body: "Restrictions ciblées, motivées juridiquement, délimitées géographiquement. Pas des arrêtés blancs couvrant un département entier." },
            { n:'04', head: "La désescalade systématique", body: "Médiation, accès aux secours garanti sans interpellation des soignants, interdiction des charges nocturnes sur des rassemblements non-violents." },
          ].map(item => (
            <div class="demand-item">
              <span class="demand-num">{item.n}.</span>
              <span><strong>{item.head}</strong>  -  {item.body}</span>
            </div>
          ))}
        </div>
      </details>

    </div>

    <!-- VI. Citation : hors accordéon -->
    <div class="manifeste-closing">
      <p class="closing-body">
        La free party a survécu au Criminal Justice Act (1994), à la loi Mariani (2001), à des centaines d'arrêtés préfectoraux et à des dizaines de saisies de matériel. Elle a survécu parce qu'elle <strong>ne dépend de personne</strong>  -  pas d'un label rachetable, pas d'un festival sans financement, pas d'un serveur qui peut être mis sous scellés.
      </p>
      <p class="closing-body">
        La loi RIPOST ajoute un chapitre au même livre. Ce wiki est notre réponse. <strong>Rendre l'information aussi difficile à saisir que la musique.</strong>
      </p>
      <div class="closing-quote">
        <span class="quote-text">Free music for free people</span>
        <span class="quote-source">SPIRAL TRIBE · 1994</span>
      </div>
    </div>

  </section>

</Layout>

<style>
  /* ═══════════════════════════════════════════════════════
     TICKER PLEINE LARGEUR
  ═══════════════════════════════════════════════════════ */
  .ticker-fullbleed {
    width: 100vw;
    position: relative;
    left: 50%;
    margin-left: -50vw;
    margin-top: -32px;
    margin-bottom: 0;
    border-top: 1px solid rgba(0, 255, 159, 0.12);
    border-bottom: 1px solid rgba(0, 255, 159, 0.12);
  }
  @media (min-width: 1024px) {
    .ticker-fullbleed { margin-top: -48px; }
  }

  .ticker-wrap {
    display: flex;
    align-items: center;
    width: 100%;
    background: rgba(0, 255, 159, 0.025);
    overflow: hidden;
    height: 36px;
  }
  .ticker-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: rgba(0, 255, 159, 0.95);
    background: rgba(0, 255, 159, 0.1);
    border-right: 1px solid rgba(0, 255, 159, 0.18);
    padding: 0 16px;
    height: 100%;
    display: flex;
    align-items: center;
    flex-shrink: 0;
    text-transform: uppercase;
  }
  .ticker-mask {
    flex: 1;
    overflow: hidden;
    height: 100%;
    display: flex;
    align-items: center;
  }
  .ticker-track {
    display: flex;
    align-items: center;
    white-space: nowrap;
    animation: ticker-scroll 60s linear infinite;
  }
  .ticker-track:hover { animation-play-state: paused; }
  .ticker-item {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: rgba(200, 200, 216, 0.65);
    letter-spacing: 0.06em;
    padding: 0 32px;
    border-right: 1px solid rgba(0, 255, 159, 0.08);
    flex-shrink: 0;
  }
  @keyframes ticker-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ═══════════════════════════════════════════════════════
     HERO
  ═══════════════════════════════════════════════════════ */
  .hero-section {
    margin-bottom: 80px;
    padding-top: 52px;
    padding-bottom: 52px;
    border-bottom: 1px solid rgba(42, 42, 58, 0.35);
    text-align: center;
  }

  /* ── HEADLINE ── */
  .hero-headline {
    margin-bottom: 40px;
    animation: hero-fade-up 0.6s ease both;
    animation-delay: 0.05s;
  }
  .hero-pretitle {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.28em;
    color: rgba(0, 255, 159, 0.5);
    text-transform: uppercase;
    margin-bottom: 18px;
    animation: hero-fade-up 0.6s ease both;
    animation-delay: 0.05s;
  }
  .hero-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    margin: 0 auto 16px;
    line-height: 0.9;
    font-family: 'Space Grotesk', 'Bebas Neue', sans-serif;
    font-weight: 800;
    text-transform: uppercase;
    animation: hero-fade-up 0.65s ease both;
    animation-delay: 0.18s;
  }
  /* Ligne haute : SOUNDSYSTEM, effacé, petit */
  .hero-title-pre {
    font-size: clamp(18px, 3.2vw, 38px);
    color: rgba(232, 232, 240, 0.2);
    letter-spacing: 0.32em;
    font-weight: 600;
  }
  .title-green {
    color: rgba(0, 255, 159, 0.4);
  }
  /* Ligne basse : HARDENING, dominant */
  .hero-title-main {
    position: relative;
    font-size: clamp(62px, 12vw, 128px);
    color: #e8e8f0;
    letter-spacing: -0.02em;
    animation: hardening-glitch 7s linear infinite;
    animation-delay: 1.8s;
  }
  .hero-title-main::before,
  .hero-title-main::after {
    content: attr(data-glitch);
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    opacity: 0;
    font-size: inherit;
    font-weight: inherit;
    letter-spacing: inherit;
    line-height: inherit;
    pointer-events: none;
  }
  .hero-title-main::before {
    color: #00ff9f;
    animation: glitch-green 7s linear infinite;
    animation-delay: 1.8s;
  }
  .hero-title-main::after {
    color: rgba(255, 0, 110, 0.75);
    animation: glitch-pink 7s linear infinite;
    animation-delay: 1.8s;
  }
  .hero-desc {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    color: rgba(190, 190, 210, 0.82);
    letter-spacing: 0.04em;
    margin: 0;
    animation: hero-fade-up 0.65s ease both;
    animation-delay: 0.3s;
  }

  .hero-stats {
    display: inline-flex;
    gap: 0;
    margin: 0 auto 36px;
    border: 1px solid rgba(42, 42, 58, 0.6);
    overflow: hidden;
    background: rgba(8, 8, 12, 0.6);
    animation: hero-fade-up 0.65s ease both;
    animation-delay: 0.42s;
  }
  .hero-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 14px 24px;
    border-right: 1px solid rgba(42, 42, 58, 0.6);
    min-width: 76px;
    position: relative;
  }
  .hero-stat:last-child { border-right: none; }
  .hero-stat::after {
    content: '';
    position: absolute;
    bottom: 0; left: 50%; transform: translateX(-50%);
    width: 20px; height: 1px;
    background: rgba(0, 255, 159, 0.2);
  }
  .stat-val {
    font-family: 'JetBrains Mono', monospace;
    font-size: 22px;
    font-weight: 700;
    color: #00ff9f;
    line-height: 1;
    margin-bottom: 5px;
  }
  .stat-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px;
    color: rgba(122, 122, 138, 0.4);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  /* ── CONTRASTE EUX / NOUS ── */
  .hero-contrast {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 0;
    max-width: 820px;
    margin: 0 auto;
    border: 1px solid rgba(42, 42, 58, 0.5);
    background: rgba(8, 8, 12, 0.5);
    overflow: hidden;
    animation: hero-fade-up 0.65s ease both;
    animation-delay: 0.56s;
  }
  .contrast-side {
    padding: 20px 28px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .contrast-side-them {
    border-right: 1px solid rgba(42, 42, 58, 0.5);
    text-align: left;
  }
  .contrast-side-us {
    border-left: 1px solid rgba(0, 255, 159, 0.12);
    text-align: right;
  }
  .contrast-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.22em;
    color: rgba(122, 122, 138, 0.3);
    text-transform: uppercase;
  }
  .contrast-tag-us {
    color: rgba(0, 255, 159, 0.4);
  }
  .contrast-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    line-height: 1.65;
    color: rgba(170, 170, 185, 0.65);
    letter-spacing: 0.02em;
    margin: 0;
  }
  .contrast-text-us {
