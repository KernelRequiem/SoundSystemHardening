---
// src/pages/carte.astro
import Layout from '../layouts/Layout.astro';
import incidents from '../data/incidents.json';

const TYPES = {
  charge:       { label: 'Charge / intervention', color: '#ff2e4d' },
  blessure:     { label: 'Blessure / mutilation',  color: '#ff8a00' },
  saisie:       { label: 'Saisie de materiel',     color: '#00d9ff' },
  gav:          { label: 'GAV / interpellation',   color: '#ffd400' },
  interdiction: { label: 'Interdiction prefect.',  color: '#ff3bd4' },
  autre:        { label: 'Autre',                  color: '#00ff9f' },
};
---

<Layout title="Carte de la repression">
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />

  <div class="carte-wrap" id="carteWrap">
    <button id="carteToggle" class="toggle-btn" title="Replier/Deployer">◀</button>

    <aside class="carte-aside" id="carteSidebar">
      <div class="aside-inner">
        <h1>CARTE DE LA RÉPRESSION</h1>
        <div class="h1sub">▸ INDEX TERRITORIAL // 1996–2026</div>

        <div class="stat">
          <span>INCIDENTS<br/>INDEXÉS</span>
          <b id="count">00</b>
        </div>

        <div class="block-title">▸ Type de répression</div>
        <div class="filters" id="filters"></div>

        <div class="block-title">▸ Période</div>
        <select id="yearFilter"><option value="all">Toutes les années</option></select>

        <button class="contrib" id="openModal">+ SIGNALER UN CAS</button>

        <p class="note">
          Aucune donnée nominative. Chaque cas est sourcé.
          Les signalements passent en validation avant publication.
        </p>
      </div>
    </aside>

    <main class="carte-main">
      <div class="topbar">
        <span class="live">● SECURE.CONNECTION</span>
        <span>SRC ▸ incidents.json</span>
        <span class="topbar-right">CC BY-SA 4.0</span>
      </div>
      <div id="map"></div>
    </main>
  </div>

  <!-- ======= MODAL SIGNALEMENT ======= -->
  <div id="reportModal" class="modal-overlay" aria-hidden="true">
    <div class="modal-box" role="dialog" aria-labelledby="modalTitle">
      <div class="modal-header">
        <span id="modalTitle">▸ SIGNALER UN CAS</span>
        <button id="closeModal" class="modal-close" aria-label="Fermer">✕</button>
      </div>
      <div id="modalForm">
        <p class="modal-note">Le signalement arrive en statut <b>En attente</b>. Un modérateur vérifie et géolocalise avant publication.</p>
        <div class="field">
          <label for="f-lieu">Lieu <span class="req">*</span></label>
          <input id="f-lieu" type="text" placeholder="ex: Redon (35)" />
        </div>
        <div class="field">
          <label for="f-date">Date <span class="req">*</span></label>
          <input id="f-date" type="date" />
        </div>
        <div class="field">
          <label for="f-type">Type de répression <span class="req">*</span></label>
          <select id="f-type">
            <option value="">-- choisir --</option>
            <option value="Charge / intervention">Charge / intervention</option>
            <option value="Blessure / mutilation">Blessure / mutilation</option>
            <option value="Saisie de materiel">Saisie de matériel</option>
            <option value="GAV / interpellation">GAV / interpellation</option>
            <option value="Interdiction prefectorale">Interdiction préfectorale</option>
            <option value="Autre">Autre</option>
          </select>
        </div>
        <div class="field">
          <label for="f-desc">Description <span class="req">*</span></label>
          <textarea id="f-desc" rows="3" placeholder="Résumé factuel, sans donnée nominative"></textarea>
        </div>
        <div class="field">
          <label for="f-bilan">Bilan</label>
          <input id="f-bilan" type="text" placeholder="ex: 2 GAV, matériel saisi" />
        </div>
        <div class="field">
          <label for="f-source">Source (URL)</label>
          <input id="f-source" type="url" placeholder="https://..." />
        </div>
        <button id="submitReport" class="submit-btn">ENVOYER LE SIGNALEMENT</button>
        <p id="formError" class="form-error" style="display:none"></p>
      </div>
      <div id="modalSuccess" style="display:none" class="modal-success">
        <div class="success-icon">✔</div>
        <p>Signalement reçu.</p>
        <p class="success-sub">Un modérateur valide et géolocalise avant publication.</p>
        <button id="closeSuccess" class="submit-btn" style="margin-top:16px">FERMER</button>
      </div>
    </div>
  </div>

  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
    is:inline
  ></script>

  <script define:vars={{ INCIDENTS: incidents, TYPES }}>
    // ---- Toggle sidebar ----
    const carteToggle = document.getElementById('carteToggle');
    const carteSidebar = document.getElementById('carteSidebar');
    const carteWrap = document.getElementById('carteWrap');
    let open = true;

    carteToggle.addEventListener('click', () => {
      open = !open;
      carteSidebar.classList.toggle('collapsed', !open);
      carteWrap.classList.toggle('collapsed', !open);
      carteToggle.textContent = open ? '◀' : '▶';
      setTimeout(() => { if (window._map) window._map.invalidateSize(); }, 320);
    });

    // ---- Carte Leaflet ----
    const map = L.map('map', { zoomControl: true }).setView([46.6, 2.4], 6);
    window._map = map;

    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; OpenStreetMap &copy; CARTO',
      maxZoom: 19,
      subdomains: 'abcd',
    }).addTo(map);

    const active = new Set(Object.keys(TYPES));
    let yearFilter = 'all';
    const layer = L.layerGroup().addTo(map);

    document.head.insertAdjacentHTML('beforeend',
      '<style>@keyframes mpulse{0%{transform:scale(1);opacity:1}50%{transform:scale(1.5);opacity:.5}100%{transform:scale(1);opacity:1}}</style>'
    );

    function dotIcon(color) {
      return L.divIcon({
        className: '',
        iconSize: [16, 16],
        iconAnchor: [8, 8],
        html: `<div style="width:14px;height:14px;border-radius:50%;background:${color};
          box-shadow:0 0 10px ${color},0 0 4px ${color};
          border:1px solid #05060a;animation:mpulse 2s infinite"></div>`,
      });
    }

    function popupHTML(i) {
      const t = TYPES[i.type] || TYPES.autre;
      const d = new Date(i.date).toLocaleDateString('fr-FR');
      const cout = i.cout_eur
        ? '~' + (i.cout_eur / 1000000).toFixed(2).replace('.', ',') + ' M€'
        : i.effectifs ? '? (' + i.effectifs + ' agents déployés)' : null;
      return `
        <span class="pop-type" style="background:${t.color}">${t.label.toUpperCase()}</span>
        <div class="pop-title">${i.titre}</div>
        <div class="pop-date">▸ ${i.lieu} // ${d}</div>
        <div class="pop-desc">${i.desc || ''}</div>
        ${i.bilan ? `<div class="pop-bilan">BILAN ▸ ${i.bilan}</div>` : ''}
        ${cout ? `<div class="pop-cout">COÛT EST. ▸ ${cout}</div>` : ''}
        ${i.statut_juridique ? `<div class="pop-statut">${i.statut_juridique.toUpperCase()}</div>` : ''}
        <div class="pop-actions">
          <div class="pop-links">
            ${i.source ? `<a href="${i.source}" target="_blank" rel="noopener">↗ SOURCE</a>` : ''}
            ${i.wiki   ? `<a href="${i.wiki}">↗ WIKI</a>` : ''}
          </div>
          <button class="pop-briefing" onclick="openBriefing('${i.id}')">&#8853; BRIEFING</button>
        </div>`;
    }

    function render() {
      layer.clearLayers();
      let n = 0;
      INCIDENTS.forEach((i) => {
        if (!active.has(i.type)) return;
        if (yearFilter !== 'all' && !String(i.date).startsWith(yearFilter)) return;
        L.marker([i.lat, i.lng], { icon: dotIcon((TYPES[i.type] || TYPES.autre).color) })
          .bindPopup(popupHTML(i), { maxWidth: 280 })
          .addTo(layer);
        n++;
      });
      document.getElementById('count').textContent = String(n).padStart(2, '0');
    }

    // Filtres par type
    const fbox = document.getElementById('filters');
    Object.entries(TYPES).forEach(([key, t]) => {
      const count = INCIDENTS.filter((i) => i.type === key).length;
      const b = document.createElement('button');
      b.className = 'chip on';
      b.innerHTML = `<span class="dot" style="background:${t.color}"></span>${t.label}<span class="ct">${count}</span>`;
      b.onclick = () => {
        active.has(key) ? active.delete(key) : active.add(key);
        b.classList.toggle('on', active.has(key));
        render();
      };
      fbox.appendChild(b);
    });

    // Filtre par année
    const years = [...new Set(INCIDENTS.map((i) => String(i.date).slice(0, 4)))].sort().reverse();
    const ySel = document.getElementById('yearFilter');
    years.forEach((y) => {
      const o = document.createElement('option');
      o.value = y; o.textContent = y; ySel.appendChild(o);
    });
    ySel.onchange = () => { yearFilter = ySel.value; render(); };

    render();

    // ──────────────────────────────────────────────────────────────────
    // REGISTRE + GÉNÉRATEUR DE BRIEFING
    // ──────────────────────────────────────────────────────────────────
    const _registry = {};
    INCIDENTS.forEach(i => { _registry[i.id] = i; });

    window.openBriefing = function(id) {
      const i = _registry[id];
      if (!i) return;
      const win = window.open('', '_blank');
      if (!win) { alert('Autorisez les popups pour générer le briefing.'); return; }
      win.document.write(buildBriefingHTML(i));
      win.document.close();
    };

    function esc(s) {
      return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
    function nl2br(s) { return esc(s).replace(/\n/g,'<br>'); }
    function row(label, val) {
      if (!val) return '';
      return `<div class="dr"><span class="dl">${label}</span><span class="dv">${esc(val)}</span></div>`;
    }
    function section(title, body) {
      if (!body || !body.trim()) return '';
      return `<section><h2>${title}</h2>${body}</section>`;
    }

    function buildBriefingHTML(i) {
      const TLABELS = { charge:'Charge / intervention', blessure:'Blessure / mutilation',
        saisie:'Saisie de matériel', gav:'GAV / interpellation',
        interdiction:'Interdiction préfectorale', autre:'Autre' };
      const dateEv  = i.date ? new Date(i.date).toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric'}) : '';
      const dateGen = new Date().toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'});

      // Section identification
      const s1 = row('Lieu',i.lieu) + row('Date',dateEv) + row('Département',i.departement)
        + row('Préfecture',i.prefecture) + row('Type de répression', TLABELS[i.type]||i.type)
        + row('Type d\'opération',i.type_operation) + row('Réf. arrêté',i.ref_arrete)
        + (i.url_arrete ? `<div class="dr"><span class="dl">Arrêté (lien)</span><span class="dv"><a href="${esc(i.url_arrete)}" target="_blank">${esc(i.url_arrete)}</a></span></div>` : '');

      // Section description & bilan
      const s2 = (i.desc ? `<p>${nl2br(i.desc)}</p>` : '')
        + (i.bilan ? `<div class="hl-box">▸ Bilan documenté : <strong>${esc(i.bilan)}</strong></div>` : '')
        + (i.source ? `<p class="meta">Source : <a href="${esc(i.source)}" target="_blank">${esc(i.source)}</a></p>` : '');

      // Section moyens déployés
      const moyensBody = row('Effectifs déployés', i.effectifs ? i.effectifs + ' agents' : null)
        + row('Unités',i.unites)
        + row('Durée intervention',i.duree_h ? i.duree_h + ' heures' : null)
        + row('Hélicoptères',i.helicopteres ? i.helicopteres + ' appareil(s)' : null)
        + row('Drones',i.drones ? i.drones + ' drone(s)' : null);
      const s3 = moyensBody || '';

      // Section coût estimé
      let s4 = '';
      if (i.cout_eur) {
        const fmt = i.cout_eur.toLocaleString('fr-FR') + ' €';
        s4 = `<div class="cout-box">
          <div class="cout-total">${fmt}</div>
          <div class="cout-label">Estimation conservatrice — deniers publics mobilisés</div>
        </div>`;
        if (i.cout_methodo) s4 += `<div class="legal-block"><p class="meta-title">▸ Méthodologie</p><p class="pre">${nl2br(i.cout_methodo)}</p></div>`;
        if (i.source_cout) s4 += `<p class="meta">Source des données : ${esc(i.source_cout)}</p>`;
        s4 += `<p class="meta avert">⚠️ Estimation basée sur des données budgétaires publiques. Non contractuelle. Vérifier avec les rapports officiels cités.</p>`;
      }

      // Section cadre juridique
      const juri = row('Statut juridique',i.statut_juridique) + row('Recours engagés',i.recours)
        + (i.jurisprudence ? `<div class="legal-block"><p class="meta-title">▸ Jurisprudence applicable</p><p class="pre">${nl2br(i.jurisprudence)}</p></div>` : '');
      const s5 = juri || '';

      // Sections failles / contre-mesures / arguments
      const s6 = i.failles ? `<p class="pre">${nl2br(i.failles)}</p>` : '';
      const s7 = i.contre_mesures ? `<p class="pre">${nl2br(i.contre_mesures)}</p>` : '';
      const s8 = i.arguments ? `<p class="pre">${nl2br(i.arguments)}</p>` : '';

      const css = `
        *{margin:0;padding:0;box-sizing:border-box}
        body{font-family:Georgia,'Times New Roman',serif;color:#111;max-width:740px;margin:0 auto;padding:40px;line-height:1.6;font-size:13px}
        .print-btn{margin-bottom:24px;padding:9px 20px;background:#111;color:#fff;border:none;cursor:pointer;font-family:monospace;font-size:11px;letter-spacing:1px}
        .print-btn:hover{background:#333}
        .brand{font-family:monospace;font-size:9px;color:#999;letter-spacing:1px;margin-bottom:6px}
        .doc-title{font-size:22px;font-weight:bold;border-bottom:2px solid #111;padding-bottom:10px;margin-bottom:6px}
        .doc-sub{font-family:monospace;font-size:9px;color:#999;margin-bottom:28px}
        h2{font-family:monospace;font-size:9px;letter-spacing:2px;color:#666;text-transform:uppercase;border-bottom:1px solid #ddd;padding-bottom:3px;margin:28px 0 12px}
        section{margin-bottom:4px}
        p{margin-bottom:8px;font-size:13px}
        .pre{white-space:pre-wrap;font-size:12px;line-height:1.7}
        .dr{display:flex;gap:12px;margin-bottom:6px;font-size:12px}
        .dl{font-family:monospace;color:#888;width:170px;flex-shrink:0;font-size:11px;padding-top:1px}
        .dv{color:#111}
        .hl-box{background:#f5f5f5;border-left:3px solid #111;padding:10px 14px;margin:12px 0;font-size:12px}
        .cout-box{background:#fffbeb;border-left:4px solid #d97706;padding:12px 16px;margin:12px 0}
        .cout-total{font-size:22px;font-weight:bold;font-family:monospace;color:#111}
        .cout-label{font-size:11px;color:#888;margin-top:2px}
        .legal-block{margin:12px 0}
        .meta{font-size:11px;color:#888;margin-bottom:6px}
        .meta-title{font-family:monospace;font-size:10px;color:#555;font-weight:bold;margin-bottom:4px}
        .avert{color:#b45309}
        a{color:#1a56db}
        .footer{margin-top:40px;padding-top:16px;border-top:1px solid #ddd;font-size:10px;color:#aaa;line-height:1.7}
        @media print{
          .print-btn{display:none}
          body{padding:0;max-width:100%}
          @page{margin:2cm;size:A4}
          h2{break-after:avoid}
        }
      `;

      return `<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <title>Briefing — ${esc(i.titre)} — ${dateEv}</title>
  <style>${css}</style>
</head>
<body>
  <button class="print-btn" onclick="window.print()">&#8595; IMPRIMER / EXPORTER PDF &nbsp; (Ctrl+P)</button>
  <div class="brand">SOUNDSYSTEMHARDENING.FR &nbsp;// BRIEFING OPÉRATIONNEL</div>
  <div class="doc-title">${esc(i.titre)}</div>
  <div class="doc-sub">Généré le ${dateGen} — Document factuel et sourcé — CC BY-SA 4.0</div>
  ${section('01 &mdash; Identification',s1)}
  ${section('02 &mdash; Description et bilan',s2)}
  ${section('03 &mdash; Moyens déployés par l\'État',s3)}
  ${section('04 &mdash; Coût estimé pour l\'État',s4)}
  ${section('05 &mdash; Cadre juridique et statut',s5)}
  ${section('06 &mdash; Failles identifiées',s6)}
  ${section('07 &mdash; Contre-mesures documentées',s7)}
  ${section('08 &mdash; Arguments de défense',s8)}
  <div class="footer">
    Document généré par SoundSystemHardening.fr —
    <a href="https://soundsystemhardening.fr/securite">soundsystemhardening.fr/securite</a><br>
    Licence CC BY-SA 4.0 — Contenu vérifiable et sourcé.<br>
    Ce document est à usage informatif. Il ne constitue pas un avis juridique.
    Consultez un avocat spécialisé pour tout recours.
  </div>
</body>
</html>`;
    }

    // ---- Modal signalement ----
    const modal       = document.getElementById('reportModal');
    const modalForm   = document.getElementById('modalForm');
    const modalSucess = document.getElementById('modalSuccess');
    const formError   = document.getElementById('formError');
    const submitBtn   = document.getElementById('submitReport');

    function openModal()  { modal.style.display = 'flex'; modal.setAttribute('aria-hidden','false'); }
    function closeModal() { modal.style.display = 'none'; modal.setAttribute('aria-hidden','true'); modalForm.style.display='block'; modalSucess.style.display='none'; formError.style.display='none'; submitBtn.disabled=false; submitBtn.textContent='ENVOYER LE SIGNALEMENT'; }

    document.getElementById('openModal').addEventListener('click', openModal);
    document.getElementById('closeModal').addEventListener('click', closeModal);
    document.getElementById('closeSuccess').addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

    document.getElementById('submitReport').addEventListener('click', async () => {
      const lieu   = document.getElementById('f-lieu').value.trim();
      const date   = document.getElementById('f-date').value.trim();
      const type   = document.getElementById('f-type').value.trim();
      const desc   = document.getElementById('f-desc').value.trim();
      const bilan  = document.getElementById('f-bilan').value.trim();
      const source = document.getElementById('f-source').value.trim();

      if (!lieu || !date || !type || !desc) {
        formError.textContent = 'Champs requis manquants : Lieu, Date, Type, Description.';
        formError.style.display = 'block';
        return;
      }
      formError.style.display = 'none';
      submitBtn.disabled = true;
      submitBtn.textContent = 'ENVOI EN COURS...';

      try {
        const res = await fetch('/api/report', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ lieu, date, type, description: desc, bilan, source }),
        });
        const data = await res.json();
        if (res.ok && data.ok) {
          modalForm.style.display = 'none';
          document.getElementById('modalSuccess').style.display = 'block';
        } else {
          throw new Error(data.error || 'Erreur inconnue');
        }
      } catch (err) {
        formError.textContent = 'Erreur : ' + err.message;
        formError.style.display = 'block';
        submitBtn.disabled = false;
        submitBtn.textContent = 'ENVOYER LE SIGNALEMENT';
      }
    });
  </script>

</Layout>

<style is:global>
  /* ---- Casser les contraintes du Layout sur cette page ---- */
  article.prose-dedsec:has(#carteWrap) {
    padding: 0 !important;
    max-width: none !important;
    margin: 0 !important;
  }

  /* Fallback pour navigateurs sans :has() */
  .carte-wrap ~ * { display: none; }

  /* ---- Réduire le logo circulaire fixe (160px → 28px) ---- */
  a.fixed .w-40 {
    width: 28px !important;
    height: 28px !important;
    border-width: 1px !important;
    box-shadow: none !important;
  }
  a.fixed {
    top: 8px !important;
    right: 8px !important;
  }

  /* ---- Carte wrap ---- */
  .carte-wrap {
    display: grid;
    grid-template-columns: 280px 1fr;
    height: calc(100dvh - 52px);
    position: relative;
    transition: grid-template-columns 0.3s ease;
    overflow: hidden;
  }

  .carte-wrap.collapsed {
    grid-template-columns: 0px 1fr;
  }

  /* ---- Toggle btn ---- */
  .toggle-btn {
    position: absolute;
    left: 280px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 1000;
    width: 18px;
    height: 48px;
    background: #0a0d14;
    border: 1px solid #10151f;
    border-left: none;
    color: #00ff9f;
    cursor: pointer;
    font-size: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: left 0.3s ease, color 0.15s;
    padding: 0;
  }

  .toggle-btn:hover { color: #00d9ff; }

  .carte-wrap.collapsed .toggle-btn {
    left: 0px;
    border-left: 1px solid #10151f;
    border-right: none;
  }

  /* ---- Sidebar ---- */
  .carte-aside {
    background: #0a0d14;
    border-right: 1px solid #10151f;
    overflow: hidden;
    transition: opacity 0.25s ease;
    width: 280px;
  }

  .carte-aside.collapsed {
    opacity: 0;
    pointer-events: none;
  }

  .aside-inner {
    padding: 16px 14px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    height: 100%;
    overflow-y: auto;
  }

  .carte-aside h1 {
    font-size: 13px;
    color: #00ff9f;
    letter-spacing: 1px;
    text-shadow: 0 0 8px rgba(0,255,159,.4);
    font-family: 'JetBrains Mono', monospace;
  }

  .h1sub { font-size: 9px; color: #00d9ff; letter-spacing: 1px; font-family: 'JetBrains Mono', monospace; }

  .block-title {
    font-size: 9px;
    color: #5a6472;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-family: 'JetBrains Mono', monospace;
    margin-top: 4px;
  }

  .filters { display: flex; flex-direction: column; gap: 5px; }

  .chip {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 6px 8px;
    cursor: pointer;
    border: 1px solid #10151f;
    background: transparent;
    color: #5a6472;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    text-align: left;
    transition: all .15s;
    white-space: nowrap;
