---
/**
 * /hardeningcore/wiki — Gestion des pages du wiki (liste + accès édition)
 */
import HardeningCore from '../../layouts/HardeningCore.astro';
import { checkAdminAuth } from '../../lib/adminAuth';
import { listWikiPages } from '../../lib/adminStore';

const auth = checkAdminAuth(Astro.cookies);
if (!auth.valid) return Astro.redirect('/hardeningcore/auth?r=/hardeningcore/wiki', 302);

const { role, email } = auth;
const nonce = Astro.locals.cspNonce;
const pages = listWikiPages();

const fmtSize = (b: number) => b < 1024 ? `${b} o` : `${(b / 1024).toFixed(1)} Ko`;
const fmtDate = (iso: string) => new Date(iso).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' });
---
<HardeningCore title="Édition du wiki" active="wiki" email={email} role={role} nonce={nonce}>

  <div class="page-head" style="display:flex;align-items:flex-end;justify-content:space-between;gap:20px;flex-wrap:wrap">
    <div>
      <div class="kick">Contenu · {pages.length} pages</div>
      <h3>Édition du wiki</h3>
      <p>Créez et modifiez les pages Markdown du wiki directement depuis l’interface, avec aperçu en direct. Chaque enregistrement est journalisé dans l’historique.</p>
    </div>
    <a href="/hardeningcore/wiki/edit" class="btn primary">
      <svg viewBox="0 0 24 24" set:html="<path d='M12 5v14M5 12h14'/>" /> Nouvelle page
    </a>
  </div>

  <div class="card" style="padding:0">
    <div style="padding:14px 18px;border-bottom:1px solid var(--line);display:flex;gap:12px;align-items:center">
      <div class="search">
        <svg viewBox="0 0 24 24" set:html="<circle cx='11' cy='11' r='7'/><path d='m21 21-4.3-4.3'/>" />
        <input id="q" class="inp" placeholder="Filtrer par titre ou slug…" style="border:none;background:transparent;padding-left:0" />
      </div>
      <span class="mono" id="count" style="color:var(--t2);font-size:11px;margin-left:auto">{pages.length} résultats</span>
    </div>

    <div style="overflow-x:auto">
      <table>
        <thead>
          <tr>
            <th>Titre</th><th>Slug</th><th>Taille</th><th>Modifié</th><th style="text-align:right">Actions</th>
          </tr>
        </thead>
        <tbody id="rows">
          {pages.map(p => (
            <tr data-search={`${p.title} ${p.slug}`.toLowerCase()}>
              <td>
                <div class="t-strong">{p.title}</div>
                <div style="font-size:11px;color:var(--t2);margin-top:2px;max-width:420px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">{p.excerpt}</div>
              </td>
              <td><span class="mono" style="font-size:11.5px;color:var(--acc2)">{p.slug}</span></td>
              <td class="mono" style="font-size:12px">{fmtSize(p.size)}</td>
              <td class="mono" style="font-size:12px;color:var(--t2)">{fmtDate(p.modified)}</td>
              <td style="text-align:right;white-space:nowrap">
                <a href={`/wiki/${encodeURIComponent(p.slug)}`} target="_blank" class="btn sm ghost" title="Voir la page publique">
                  <svg viewBox="0 0 24 24" set:html="<path d='M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z'/><circle cx='12' cy='12' r='3'/>" />
                </a>
                <a href={`/hardeningcore/wiki/edit?slug=${encodeURIComponent(p.slug)}`} class="btn sm">
                  <svg viewBox="0 0 24 24" set:html="<path d='M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7'/><path d='M18.5 2.5a2.1 2.1 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5Z'/>" /> Éditer
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <style is:inline>
    .search{display:flex;align-items:center;gap:9px;flex:1;max-width:420px}
    .search svg{width:16px;height:16px;stroke:var(--t2);stroke-width:2;fill:none;flex-shrink:0}
  </style>

  <script nonce={nonce} is:inline>
    (function(){
      var q = document.getElementById('q'), rows = document.getElementById('rows'), count = document.getElementById('count');
      q.addEventListener('input', function(){
        var term = q.value.toLowerCase().trim(), n = 0;
        rows.querySelectorAll('tr').forEach(function(tr){
          var match = tr.getAttribute('data-search').indexOf(term) !== -1;
          tr.style.display = match ? '' : 'none';
          if(match) n++;
        });
        count.textContent = n + ' résultats';
      });
    })();
  </script>

</HardeningCore>
