---
/**
 * /hardeningcore/historique — Journal des modifications (qui / quoi / quand)
 * Lecture seule du journal append-only (adminStore.readHistory).
 */
import HardeningCore from '../../layouts/HardeningCore.astro';
import { checkAdminAuth } from '../../lib/adminAuth';
import { readHistory } from '../../lib/adminStore';

const auth = checkAdminAuth(Astro.cookies);
if (!auth.valid) return Astro.redirect('/hardeningcore/auth?r=/hardeningcore/historique', 302);

const { role, email } = auth;
const nonce = Astro.locals.cspNonce;
const history = readHistory(400);

const actionMeta: Record<string, { label: string; cat: string; color: string }> = {
  'wiki.create':          { label: 'Page wiki créée',        cat: 'wiki',       color: 'var(--acc)' },
  'wiki.update':          { label: 'Page wiki modifiée',     cat: 'wiki',       color: 'var(--acc)' },
  'wiki.delete':          { label: 'Page wiki supprimée',    cat: 'wiki',       color: 'var(--acc)' },
  'incident.create':      { label: 'Incident ajouté',        cat: 'carte',      color: 'var(--blue)' },
  'incident.update':      { label: 'Incident modifié',       cat: 'carte',      color: 'var(--blue)' },
  'incident.delete':      { label: 'Incident supprimé',      cat: 'carte',      color: 'var(--blue)' },
  'moderation.approved':  { label: 'Contribution validée',   cat: 'modération', color: 'var(--violet)' },
  'moderation.rejected':  { label: 'Contribution rejetée',   cat: 'modération', color: 'var(--violet)' },
  'legal.validated':      { label: 'Validé (juridique)',     cat: 'légal',      color: 'var(--amber)' },
  'legal.review':         { label: 'Mis en revue',           cat: 'légal',      color: 'var(--amber)' },
  'legal.flagged':        { label: 'Signalé à corriger',     cat: 'légal',      color: 'var(--amber)' },
  'legal.draft':          { label: 'Repassé en brouillon',   cat: 'légal',      color: 'var(--amber)' },
};
const meta = (a: string) => actionMeta[a] ?? { label: a, cat: 'autre', color: 'var(--t2)' };

const fmt = (iso: string) => new Date(iso).toLocaleString('fr-FR', { day:'2-digit', month:'2-digit', year:'2-digit', hour:'2-digit', minute:'2-digit' });

// Catégories présentes pour les filtres.
const cats = Array.from(new Set(history.map(h => meta(h.action).cat)));
const actors = Array.from(new Set(history.map(h => h.actor)));
---
<HardeningCore title="Historique" active="history" email={email} role={role} nonce={nonce}>

  <div class="page-head">
    <div class="kick">Traçabilité · {history.length} événements</div>
    <h3>Historique des modifications</h3>
    <p>Journal de toutes les actions effectuées dans HardeningCore : qui a modifié quoi et quand. Transparence interne et traçabilité des changements de contenu.</p>
  </div>

  <div class="filters">
    <input id="q" class="inp" placeholder="Rechercher (cible, action, auteur)…" style="max-width:320px" />
    <select id="f-cat" class="sel" style="max-width:170px">
      <option value="">Toutes catégories</option>
      {cats.map(c => <option value={c}>{c}</option>)}
    </select>
    <select id="f-actor" class="sel" style="max-width:200px">
      <option value="">Tous les auteurs</option>
      {actors.map(a => <option value={a}>{a.split('@')[0]}</option>)}
    </select>
    <span class="mono" id="count" style="color:var(--t2);font-size:11px;margin-left:auto">{history.length} événements</span>
  </div>

  {history.length === 0 ? (
    <div class="card empty">
      <svg viewBox="0 0 24 24" set:html="<circle cx='12' cy='12' r='9'/><path d='M12 7v5l3 2'/>" />
      <div>Aucun événement journalisé pour l’instant.<br/>Les actions (édition, modération, carte, validation) apparaîtront ici.</div>
    </div>
  ) : (
    <div class="card" style="padding:0">
      <div style="overflow-x:auto">
        <table>
          <thead><tr><th style="width:130px">Date</th><th>Action</th><th>Cible</th><th>Auteur</th><th>Détail</th></tr></thead>
          <tbody id="rows">
            {history.map(h => {
              const m = meta(h.action);
              return (
                <tr data-search={`${m.label} ${h.target} ${h.actor} ${h.meta ?? ''}`.toLowerCase()} data-cat={m.cat} data-actor={h.actor}>
                  <td class="mono" style="font-size:11px;color:var(--t2);white-space:nowrap">{fmt(h.ts)}</td>
                  <td><span class="act-dot" style={`background:${m.color}`}></span><span class="t-strong" style="font-size:12.5px">{m.label}</span></td>
                  <td><span class="mono" style="font-size:11px;color:var(--acc2)">{h.target}</span></td>
                  <td class="mono" style="font-size:11px;color:var(--t1)">{h.actor.split('@')[0]}</td>
                  <td style="font-size:11.5px;color:var(--t2);max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">{h.meta ?? '—'}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  )}

  <style is:inline>
    .filters{display:flex;gap:12px;align-items:center;margin-bottom:18px;flex-wrap:wrap}
    .act-dot{display:inline-block;width:7px;height:7px;border-radius:50%;margin-right:8px;vertical-align:middle}
  </style>

  <script nonce={nonce} is:inline>
    (function(){
      var q = document.getElementById('q'), cat = document.getElementById('f-cat'),
          actor = document.getElementById('f-actor'), rows = document.getElementById('rows'),
          count = document.getElementById('count');
      if(!rows) return;
      function apply(){
        var term = q.value.toLowerCase().trim(), c = cat.value, a = actor.value, n = 0;
        rows.querySelectorAll('tr').forEach(function(tr){
          var ok = (!term || tr.getAttribute('data-search').indexOf(term) !== -1)
                && (!c || tr.getAttribute('data-cat') === c)
                && (!a || tr.getAttribute('data-actor') === a);
          tr.style.display = ok ? '' : 'none'; if(ok) n++;
        });
        count.textContent = n + ' événements';
      }
      [q,cat,actor].forEach(function(el){ el.addEventListener('input', apply); el.addEventListener('change', apply); });
    })();
  </script>

</HardeningCore>
