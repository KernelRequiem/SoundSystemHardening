---
// src/pages/flyer.astro
// Flyer terrain imprimable : QR (vers le site) + URL + accroche.
// Optimise impression noir/blanc sur A6. Le QR pointe vers le site (decouverte),
// le contact passe par le formulaire web (/contact), pas par Signal.
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Flyer imprimable"
  category="DIFFUSION"
  description="Flyer A6 imprimable noir et blanc : QR vers le wiki, accroche, URL. À distribuer en rassemblement, meetup, événement terrain."
>

  <div class="no-print">
    <h1>Flyer imprimable</h1>
    <p class="text-dedsec-muted text-sm font-mono tracking-widest uppercase mb-6">
      ▸ Format A6 · Noir & blanc · Prêt à coller
    </p>

    <div class="info-box mb-6">
      Aperçu ci-dessous. Le bouton <strong>Imprimer</strong> sort une page A6 noir sur blanc,
      sans le reste de l'interface. Idéal pour les rassemblements, meetups et événements terrain.
      Le QR mène au wiki ; le contact se fait par le formulaire du site.
    </div>

    <div class="flex flex-wrap gap-3 mb-8">
      <button id="printBtn" class="btn-neon" type="button">⎙ Imprimer le flyer</button>
      <a href="/flyer-qr.png" download class="btn-neon" style="border-color:rgba(122,122,138,0.4);color:#7a7a8a;">⬇ QR seul (PNG)</a>
      <a href="/presse" class="btn-neon" style="border-color:rgba(122,122,138,0.4);color:#7a7a8a;">→ Dossier de presse</a>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- CARTE FLYER (sert d'aperçu écran ET de zone imprimée)   -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <div class="flyer-card">
    <div class="flyer-inner">
      <div class="flyer-tag">// RESISTANCE TOOLKIT</div>

      <div class="flyer-title">SOUNDSYSTEM<br/>HARDENING</div>

      <div class="flyer-accroche">
        Tes droits. Ta sécu numérique. Ton terrain.<br/>
        Le wiki du mouvement free party.
      </div>

      <div class="flyer-qr-wrap">
        <img src="/flyer-qr.png" alt="QR code vers soundsystemhardening.fr" class="flyer-qr no-border" />
      </div>

      <div class="flyer-scan">SCANNE · LIS · PARTAGE</div>
      <div class="flyer-url">soundsystemhardening.fr</div>

      <div class="flyer-footer">
        Droits face aux contrôles · OpSec · Recours juridiques · Carte des incidents<br/>
        Un truc à signaler ? Formulaire sur soundsystemhardening.fr/contact
      </div>
    </div>
  </div>

  <script>
    document.getElementById('printBtn')?.addEventListener('click', () => window.print());
  </script>

</Layout>

<style is:global>
  /* ───────── Aperçu écran : carte A6 façon papier ───────── */
  .flyer-card {
    width: 105mm;
    height: 148mm;
    max-width: 100%;
    margin: 0 auto 2rem;
    background: #ffffff;
    color: #000000;
    border: 1px solid #2a2a3a;
    box-shadow: 0 0 40px rgba(0, 255, 159, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .flyer-inner {
    width: 100%;
    height: 100%;
    box-sizing: border-box;
    padding: 9mm 7mm;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    font-family: 'JetBrains Mono', monospace;
    color: #000;
  }

  .flyer-tag {
    font-size: 8pt;
    font-weight: 700;
    letter-spacing: 0.22em;
    color: #000;
    border: 1.5px solid #000;
    padding: 2px 8px;
    margin-bottom: 6mm;
  }

  .flyer-title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 20pt;
    line-height: 1.02;
    letter-spacing: -0.01em;
    color: #000;
    margin-bottom: 4mm;
  }

  .flyer-accroche {
    font-size: 8.5pt;
    line-height: 1.5;
    color: #111;
    margin-bottom: 6mm;
    max-width: 80mm;
  }

  .flyer-qr-wrap {
    border: 2px solid #000;
    padding: 3mm;
    margin-bottom: 4mm;
    background: #fff;
  }

  .flyer-qr {
    display: block;
    width: 42mm;
    height: 42mm;
    image-rendering: pixelated;
  }

  .flyer-scan {
    font-size: 8pt;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: #000;
    margin-bottom: 1.5mm;
  }

  .flyer-url {
    font-size: 12pt;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: #000;
    margin-bottom: auto;
  }

  .flyer-footer {
    font-size: 6.5pt;
    line-height: 1.5;
    color: #222;
    border-top: 1px solid #000;
    padding-top: 2.5mm;
    margin-top: 5mm;
    width: 100%;
  }

  /* ───────── Impression : A6 noir sur blanc, rien d'autre ───────── */
  @media print {
    @page {
      size: A6;
      margin: 0;
    }
    /* On masque tout, on ne réaffiche que la carte flyer. */
    body { visibility: hidden; background: #fff !important; }
    .flyer-card, .flyer-card * { visibility: visible; }
    .flyer-card {
      position: fixed;
      top: 0;
      left: 0;
      width: 105mm;
      height: 148mm;
      margin: 0;
      border: none;
      box-shadow: none;
      background: #fff;
    }
    .no-print { display: none !important; }
    /* Neutralise l'éventuel reset prose / couleurs sombres héritées */
    .flyer-inner, .flyer-title, .flyer-tag, .flyer-url, .flyer-scan { color: #000 !important; }
  }
</style>
