---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Évaluateur de terrain">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />

  <div class="ter-wrap" id="terWrap">
    <button id="terToggle" class="ter-toggle">◀</button>

    <aside class="ter-aside" id="terSidebar">
      <div class="ter-inner">
        <div>
          <h1 class="ter-h1">ÉVALUATEUR DE TERRAIN</h1>
          <div class="ter-sub">▸ PRÉSÉLECTION DE ZONE · OSM/OVERPASS</div>
        </div>

        <div class="ter-warn">
          <strong>⚠ AVANT D'UTILISER</strong>
          <p>La coordonnée (arrondie à ~1 km) est envoyée à <b>OpenStreetMap/Overpass</b> depuis ton navigateur. Utilise <b>Tor</b> si la zone est sensible. Cet outil présélectionne un secteur, la validation finale se fait en reconnaissance physique, hors réseau.</p>
        </div>

        <div class="ter-block">
          <div class="ter-label">▸ Rayon d'analyse</div>
          <select id="terRayon">
            <option value="500">500 m</option>
            <option value="1000" selected>1 km</option>
            <option value="1500">1,5 km</option>
            <option value="2000">2 km</option>
          </select>
        </div>

        <div class="ter-block">
          <div class="ter-label">▸ Zone sélectionnée</div>
          <div id="terCoord" class="ter-coord">Cliquez sur la carte pour poser un point</div>
        </div>

        <button id="terAnalyze" class="ter-btn" disabled>ANALYSER CETTE ZONE</button>

        <div id="terStatus" class="ter-status" style="display:none">
          <div class="ter-spinner"></div>
          <span id="terStatusMsg">Interrogation Overpass...</span>
        </div>

        <p id="terError" class="ter-err" style="display:none"></p>

        <div id="terReport" class="ter-report" style="display:none">
          <div class="ter-score-wrap">
            <span class="ter-score-label">RISQUE</span>
            <span id="terScore" class="ter-score">-</span>
          </div>
          <ul id="terFacteurs" class="ter-facteurs"></ul>
          <div id="terMeta" class="ter-meta"></div>
          <p class="ter-note" id="terPrecision"></p>
        </div>
      </div>
    </aside>

    <main class="ter-main">
      <div class="ter-topbar">
        <span class="ter-live">● DIRECT.OSM</span>
        <span>coordonnée arrondie ~1 km · aucun serveur intermédiaire</span>
        <span class="ter-topright">CC BY-SA · OpenStreetMap</span>
      </div>
      <div id="terMap"></div>
    </main>
  </div>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin="" is:inline></script>

  <script is:inline>
  (function () {

    // ── Sidebar toggle ──────────────────────────────────────────────────────
    let sidebarOpen = true;
    document.getElementById('terToggle').addEventListener('click', function () {
      sidebarOpen = !sidebarOpen;
      document.getElementById('terSidebar').classList.toggle('collapsed', !sidebarOpen);
      document.getElementById('terWrap').classList.toggle('collapsed', !sidebarOpen);
      this.textContent = sidebarOpen ? '◀' : '▶';
      setTimeout(function () { if (window._terMap) window._terMap.invalidateSize(); }, 320);
    });

    // ── Carte Leaflet ───────────────────────────────────────────────────────
    var map = L.map('terMap', { zoomControl: true }).setView([46.6, 2.4], 6);
    window._terMap = map;
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; OpenStreetMap &copy; CARTO',
      maxZoom: 18,
      subdomains: 'abcd',
    }).addTo(map);

    var SCORE_COLORS = { faible: '#00ff9f', modéré: '#60a5fa', élevé: '#ff8a00', critique: '#ff4444' };
    var marker = null, circle = null;
    var rLat = null, rLng = null;

    var coordEl   = document.getElementById('terCoord');
    var analyzeBtn = document.getElementById('terAnalyze');
    var rayonEl   = document.getElementById('terRayon');
    var errEl     = document.getElementById('terError');
    var reportEl  = document.getElementById('terReport');
    var statusEl  = document.getElementById('terStatus');
    var statusMsg = document.getElementById('terStatusMsg');

    function round2(n) { return Math.round(n * 100) / 100; }
    function roundDist(m) { return Math.round(m / 50) * 50; }

    function placePin(lat, lng) {
      rLat = round2(lat);
      rLng = round2(lng);
      if (marker) map.removeLayer(marker);
      if (circle) map.removeLayer(circle);
      marker = L.circleMarker([rLat, rLng], {
        radius: 6, color: '#00ff9f', fillColor: '#00ff9f', fillOpacity: 1, weight: 1,
      }).addTo(map);
      circle = L.circle([rLat, rLng], {
        radius: parseInt(rayonEl.value, 10),
        color: '#00ff9f', fillColor: '#00ff9f', fillOpacity: 0.06, weight: 1, dashArray: '4 4',
      }).addTo(map);
      coordEl.innerHTML = 'Zone analysée (arrondie) :<br><b>' + rLat.toFixed(2) + ', ' + rLng.toFixed(2) + '</b><br><span class="ter-coord-note">Clic précis non transmis</span>';
      analyzeBtn.disabled = false;
      reportEl.style.display = 'none';
      errEl.style.display = 'none';
    }

    map.on('click', function (e) { placePin(e.latlng.lat, e.latlng.lng); });
    rayonEl.addEventListener('change', function () { if (rLat !== null) placePin(rLat, rLng); });

    // ── Overpass ────────────────────────────────────────────────────────────
    // Deux endpoints en cascade : si le premier timeout/échoue, on tente le second
    var ENDPOINTS = [
      'https://overpass-api.de/api/interpreter',
      'https://overpass.kumi.systems/api/interpreter',
    ];

    function buildQuery(lat, lng, radius) {
      return '[out:json][timeout:20];\n(\n' +
        '  way["building"](around:' + radius + ',' + lat + ',' + lng + ');\n' +
        '  way["landuse"~"residential|military|industrial|farmland|farmyard|forest|commercial|retail"](around:' + radius + ',' + lat + ',' + lng + ');\n' +
        '  way["natural"~"water|wood"](around:' + radius + ',' + lat + ',' + lng + ');\n' +
        '  way["leisure"="nature_reserve"](around:' + radius + ',' + lat + ',' + lng + ');\n' +
        ');\nout center tags;';
    }

    function haversine(lat1, lng1, lat2, lng2) {
      var R = 6371000, toRad = function (d) { return d * Math.PI / 180; };
      var dLat = toRad(lat2 - lat1), dLng = toRad(lng2 - lng1);
      var a = Math.sin(dLat / 2) * Math.sin(dLat / 2)
        + Math.cos(toRad(lat1)) * Math.cos(toRad(lat2))
        * Math.sin(dLng / 2) * Math.sin(dLng / 2);
      return 2 * R * Math.asin(Math.sqrt(a));
    }

    function classifyZone(tags) {
      if (!tags) return null;
      var lu = tags.landuse;
      if (lu === 'residential') return 'résidentielle';
      if (lu === 'military')    return 'militaire';
      if (lu === 'industrial')  return 'industrielle';
      if (lu === 'commercial' || lu === 'retail')   return 'commerciale';
      if (lu === 'farmland'   || lu === 'farmyard') return 'agricole';
      if (lu === 'forest'     || tags.natural === 'wood') return 'forêt';
      if (tags.natural === 'water') return "plan d'eau";
      if (tags.leisure === 'nature_reserve' || tags.boundary === 'protected_area') return 'zone protégée';
      return null;
    }

    function scoreTerrain(nearestHab, habCount, zones, militaire, protegee) {
      var facteurs = [], niveau = 0;
      if (nearestHab === null) {
        facteurs.push('Aucune habitation dans le rayon - favorable');
      } else if (nearestHab < 300) {
        niveau = Math.max(niveau, 3);
        facteurs.push('Habitation à ~' + nearestHab + ' m - risque très élevé');
      } else if (nearestHab < 600) {
        niveau = Math.max(niveau, 2);
        facteurs.push('Habitation à ~' + nearestHab + ' m - risque élevé');
      } else if (nearestHab < 1000) {
        niveau = Math.max(niveau, 1);
        facteurs.push('Habitation à ~' + nearestHab + ' m - risque modéré');
      } else {
        facteurs.push('Habitation à plus de 1 km - risque faible');
      }
      if (habCount > 10) { niveau = Math.max(niveau, 2); facteurs.push(habCount + ' bâtiments dans le rayon - secteur habité'); }
      else if (habCount > 0) { facteurs.push(habCount + ' bâtiment(s) dans le rayon'); }
      if (zones.indexOf('résidentielle') !== -1) { niveau = Math.max(niveau, 3); facteurs.push('Zone résidentielle détectée - risque maximal'); }
      if (protegee) { niveau = Math.max(niveau, 2); facteurs.push('Zone naturelle protégée - risque juridique'); }
      if (militaire) { niveau = Math.max(niveau, 1); facteurs.push('Zone militaire - cadre légal spécifique'); }
      if (zones.length > 0) { facteurs.push('Zones détectées : ' + zones.join(', ')); }
      return { score: ['faible', 'modéré', 'élevé', 'critique'][niveau], facteurs: facteurs };
    }

    function processElements(elements) {
      var nearestHabRaw = null, habCount = 0, zonesArr = [], militaire = false, protegee = false;
      var seen = {};
      for (var i = 0; i < elements.length; i++) {
        var el = elements[i], tags = el.tags || {}, c = el.center || {};
        if (tags.building && c.lat != null && c.lon != null) {
          habCount++;
          var d = haversine(rLat, rLng, c.lat, c.lon);
          if (nearestHabRaw === null || d < nearestHabRaw) nearestHabRaw = d;
        }
        var zone = classifyZone(tags);
        if (zone && !seen[zone]) { seen[zone] = true; zonesArr.push(zone); }
        if (tags.landuse === 'military') militaire = true;
        if (tags.leisure === 'nature_reserve' || tags.boundary === 'protected_area') protegee = true;
      }
      var nearestHab = nearestHabRaw === null ? null : roundDist(nearestHabRaw);
      return scoreTerrain(nearestHab, habCount, zonesArr, militaire, protegee);
    }

    function setStatus(msg) { statusMsg.textContent = msg; statusEl.style.display = 'flex'; }
    function hideStatus() { statusEl.style.display = 'none'; }

    async function queryOverpass(endpoint, query) {
      var controller = new AbortController();
      var tid = setTimeout(function () { controller.abort(); }, 22000);
      try {
        var res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: 'data=' + encodeURIComponent(query),
          signal: controller.signal,
        });
        clearTimeout(tid);
        if (!res.ok) throw new Error('HTTP ' + res.status);
        return await res.json();
      } catch (e) {
        clearTimeout(tid);
        throw e;
      }
    }

    analyzeBtn.addEventListener('click', async function () {
      if (rLat === null) return;
      analyzeBtn.disabled = true;
      errEl.style.display = 'none';
      reportEl.style.display = 'none';

      var rayon = parseInt(rayonEl.value, 10);
      var query = buildQuery(rLat, rLng, rayon);
      var data = null;

      for (var i = 0; i < ENDPOINTS.length; i++) {
        try {
          setStatus((i === 0 ? 'Interrogation Overpass' : 'Tentative miroir') + '... (' + (i + 1) + '/' + ENDPOINTS.length + ')');
          data = await queryOverpass(ENDPOINTS[i], query);
          break;
        } catch (e) {
          if (i === ENDPOINTS.length - 1) {
            hideStatus();
            errEl.textContent = 'Service cartographique injoignable. Vérifie ta connexion ou réessaie dans quelques instants.';
            errEl.style.display = 'block';
            analyzeBtn.disabled = false;
            return;
          }
        }
      }

      hideStatus();

      if (!data || !data.elements) {
        errEl.textContent = 'Réponse Overpass invalide.';
        errEl.style.display = 'block';
        analyzeBtn.disabled = false;
        return;
      }

      var result = processElements(data.elements);
      renderReport(result, data.elements);
      analyzeBtn.disabled = false;
    });

    function renderReport(result, elements) {
      var color = SCORE_COLORS[result.score] || '#00ff9f';
      var scoreEl = document.getElementById('terScore');
      scoreEl.textContent = result.score.toUpperCase();
      scoreEl.style.color = color;
      scoreEl.style.textShadow = '0 0 10px ' + color + '66';
      if (circle) circle.setStyle({ color: color, fillColor: color });
      if (marker) marker.setStyle({ color: color, fillColor: color });

      var ul = document.getElementById('terFacteurs');
      ul.innerHTML = '';
      result.facteurs.forEach(function (f) {
        var li = document.createElement('li');
        li.textContent = f;
        ul.appendChild(li);
      });

      // Compter bâtiments et zones depuis les éléments bruts
      var habCount = 0, militaire = false, protegee = false;
      var nearestHabRaw = null;
      var zonesSet = {};
      for (var i = 0; i < elements.length; i++) {
        var el = elements[i], tags = el.tags || {}, c = el.center || {};
        if (tags.building && c.lat != null) { habCount++; var d = haversine(rLat, rLng, c.lat, c.lon); if (nearestHabRaw === null || d < nearestHabRaw) nearestHabRaw = d; }
        if (tags.landuse === 'military') militaire = true;
        if (tags.leisure === 'nature_reserve' || tags.boundary === 'protected_area') protegee = true;
      }
      var nearestHab = nearestHabRaw === null ? null : roundDist(nearestHabRaw);
      var hab = nearestHab === null ? 'aucune dans le rayon' : '~' + nearestHab + ' m';

      document.getElementById('terMeta').innerHTML =
        '<div><span>Habitation proche</span><b>' + hab + '</b></div>' +
        '<div><span>Bâtiments détectés</span><b>' + habCount + '</b></div>' +
        (militaire ? '<div><span>Zone militaire</span><b style="color:#ff8a00">oui</b></div>' : '') +
        (protegee  ? '<div><span>Zone protégée</span><b style="color:#ff8a00">oui</b></div>'  : '');

      document.getElementById('terPrecision').textContent =
        "Analyse sur zone ~1 km. Les données OSM peuvent être incomplètes selon le secteur. Validation finale en reconnaissance physique, hors réseau.";

      reportEl.style.display = 'block';
    }

  })();
  </script>
</Layout>

<style is:global>
  article.prose-dedsec:has(#terWrap) { padding: 0 !important; max-width: none !important; margin: 0 !important; }

  .ter-wrap {
    display: grid;
    grid-template-columns: 300px 1fr;
    height: calc(100dvh - 88px);
    position: relative;
    transition: grid-template-columns .3s ease;
    overflow: hidden;
  }
  .ter-wrap.collapsed { grid-template-columns: 0 1fr; }

  .ter-toggle {
    position: absolute; left: 300px; top: 50%; transform: translateY(-50%);
    z-index: 1000; width: 18px; height: 48px;
    background: #0a0d14; border: 1px solid #2a2a3a; border-left: none;
    color: #00ff9f; cursor: pointer; font-size: 10px;
    display: flex; align-items: center; justify-content: center;
    transition: left .3s ease; padding: 0;
  }
  .ter-toggle:hover { background: rgba(0,255,159,0.08); }
  .ter-wrap.collapsed .ter-toggle { left: 0; border-left: 1px solid #2a2a3a; border-right: none; }

  .ter-aside {
    background: #08080c; border-right: 1px solid #1a1f2e;
    overflow: hidden; transition: opacity .25s ease; width: 300px;
  }
  .ter-aside.collapsed { opacity: 0; pointer-events: none; }

  .ter-inner {
    padding: 16px 14px; display: flex; flex-direction: column;
    gap: 14px; height: 100%; overflow-y: auto;
    font-family: 'JetBrains Mono', monospace;
  }

  .ter-h1 { font-size: 12px !important; color: #00ff9f !important; letter-spacing: 1.5px; text-shadow: 0 0 8px rgba(0,255,159,.4); margin: 0 !important; padding: 0 !important; border: none !important; }
  .ter-sub { font-size: 9px; color: rgba(0,255,159,0.4); letter-spacing: 1px; margin-top: 3px; }

  .ter-warn {
    background: rgba(255,68,68,.05); border-left: 3px solid rgba(255,68,68,.4);
    padding: 10px; font-size: 9px; line-height: 1.7; color: #7a7a8a;
  }
  .ter-warn strong { color: #ff4444; font-size: 9px; letter-spacing: 1px; display: block; margin-bottom: 4px; }
  .ter-warn p { margin: 0; }
  .ter-warn b { color: #ffd400; }

  .ter-block { display: flex; flex-direction: column; gap: 5px; }
  .ter-label { font-size: 9px; color: #5a6472; letter-spacing: 2px; text-transform: uppercase; }

  #terRayon {
    width: 100%; background: #05060a; color: #00ff9f;
    border: 1px solid #1a1f2e; padding: 7px;
    font-family: 'JetBrains Mono', monospace; font-size: 11px; outline: none;
  }
  #terRayon:focus { border-color: rgba(0,255,159,0.4); }

  .ter-coord {
    font-size: 11px; color: #c8c8d8; border: 1px solid #1a1f2e;
    padding: 8px; line-height: 1.6;
  }
  .ter-coord b { color: #00ff9f; font-size: 13px; }
  .ter-coord-note { font-size: 8px; color: #5a6472; }

  .ter-btn {
    padding: 11px; background: transparent; border: 1px solid rgba(0,255,159,0.5);
    color: #00ff9f; font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 1px; cursor: pointer; transition: all .15s;
  }
  .ter-btn:hover:not(:disabled) { background: #00ff9f; color: #05060a; }
  .ter-btn:disabled { opacity: .3; cursor: not-allowed; }

  .ter-status {
    display: flex; align-items: center; gap: 8px;
    font-size: 10px; color: rgba(0,255,159,0.6);
  }
  .ter-spinner {
    width: 10px; height: 10px; border: 1px solid rgba(0,255,159,0.2);
    border-top-color: #00ff9f; border-radius: 50%;
    animation: spin .8s linear infinite; flex-shrink: 0;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .ter-err { font-size: 10px; color: #ff4444; line-height: 1.6; }

  .ter-report { border-top: 1px solid #1a1f2e; padding-top: 12px; display: flex; flex-direction: column; gap: 10px; }
  .ter-score-wrap { display: flex; align-items: baseline; justify-content: space-between; border: 1px solid #1a1f2e; padding: 10px; }
  .ter-score-label { font-size: 9px; color: #5a6472; letter-spacing: 2px; }
  .ter-score { font-size: 22px; font-weight: 700; }

  .ter-facteurs { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 6px; }
  .ter-facteurs li { font-size: 10px; color: #c8c8d8; line-height: 1.5; padding-left: 12px; position: relative; }
  .ter-facteurs li::before { content: '▸'; position: absolute; left: 0; color: #00ff9f; }

  .ter-meta { display: flex; flex-direction: column; gap: 5px; border-top: 1px solid #1a1f2e; padding-top: 8px; }
  .ter-meta div { display: flex; justify-content: space-between; font-size: 10px; }
  .ter-meta span { color: #5a6472; }
  .ter-meta b { color: #e8e8f0; }

  .ter-note { font-size: 8px; color: #3a3a4a; line-height: 1.7; border-top: 1px solid #1a1f2e; padding-top: 8px; }

  .ter-main { position: relative; overflow: hidden; }
  #terMap { position: absolute; inset: 0; top: 34px; background: #05060a; }

  .ter-topbar {
    position: absolute; top: 0; left: 0; right: 0; z-index: 500; height: 34px;
    background: rgba(8,8,12,.92); border-bottom: 1px solid #1a1f2e;
    display: flex; align-items: center; padding: 0 14px; gap: 14px;
    font-size: 10px; letter-spacing: 1px; color: #5a6472;
    backdrop-filter: blur(4px); font-family: 'JetBrains Mono', monospace;
  }
  .ter-live { color: #00ff9f; animation: tblink 1.4s infinite; }
  @keyframes tblink { 50% { opacity: .3; } }
  .ter-topright { margin-left: auto; }

  .leaflet-container { background: #05060a; font-family: 'JetBrains Mono', monospace; }
  .leaflet-popup-content-wrapper { background: #0a0d14; color: #e8e8f0; border: 1px solid rgba(0,255,159,0.3); border-radius: 0; }
  .leaflet-control-zoom a { background: #0a0d14 !important; color: #00ff9f !important; border: 1px solid #1a1f2e !important; border-radius: 0 !important; }
  .leaflet-control-zoom a:hover { background: rgba(0,255,159,0.1) !important; }
  .leaflet-control-attribution { background: rgba(5,6,10,.8) !important; color: #3a3a4a !important; font-size: 9px !important; }

  @media (max-width: 760px) {
    .ter-wrap { grid-template-columns: 1fr; grid-template-rows: auto 1fr; height: 100dvh; }
    .ter-aside { width: 100%; max-height: 44vh; }
    .ter-toggle { display: none; }
  }
</style>
