// ─── TYPES ────────────────────────────────────────────────────────────────
interface Choice { label: string; next: string; }
interface Node {
  id: string;
  text: string;
  type: 'question' | 'result';
  color?: 'green' | 'orange' | 'red';
  icon?: string;
  choices?: Choice[];
  actions?: string[];
  rights?: string[];
  links?: { label: string; href: string }[];
}

// ─── ÉTAT ─────────────────────────────────────────────────────────────────
let history: string[] = ['root'];

// ─── RENDU ────────────────────────────────────────────────────────────────
function colorClass(color?: string) {
  if (color === 'green')  return { border: 'border-neon-green',  text: 'text-neon-green',  bg: 'bg-neon-green/10' };
  if (color === 'orange') return { border: 'border-neon-orange', text: 'text-neon-orange', bg: 'bg-neon-orange/10' };
  if (color === 'red')    return { border: 'border-neon-pink',   text: 'text-neon-pink',   bg: 'bg-neon-pink/10' };
  return { border: 'border-neon-cyan', text: 'text-neon-cyan', bg: 'bg-neon-cyan/10' };
}

function renderBreadcrumb(): string {
  if (history.length <= 1) return '';
  return `
    <div class="flex items-center gap-1 flex-wrap mb-6 text-[10px] font-mono text-dedsec-muted">
      ${history.map((id, i) => {
        const node = tree[id];
        const label = i === 0 ? 'DÉBUT' : node.text.slice(0, 28) + (node.text.length > 28 ? '…' : '');
        const isLast = i === history.length - 1;
        return `
          ${i > 0 ? '<span class="text-dedsec-border">›</span>' : ''}
          ${isLast
            ? `<span class="text-neon-green">${label}</span>`
            : `<button class="hover:text-neon-cyan transition-colors underline underline-offset-2" data-goto="${i}">${label}</button>`
          }
        `;
      }).join('')}
    </div>
  `;
}

function renderNode(id: string): string {
  const node = tree[id];
  if (!node) return '<p class="text-neon-pink">Nœud introuvable</p>';
  const c = colorClass(node.color);

  if (node.type === 'question') {
    return `
      ${renderBreadcrumb()}
      <div class="card-neon border ${c.border} mb-6 animate-fade-in">
        <div class="flex items-start gap-3">
          <span class="${c.text} font-mono text-lg mt-0.5">?</span>
          <p class="font-mono text-dedsec-text text-base font-bold">${node.text}</p>
        </div>
      </div>
      <div class="space-y-3">
        ${(node.choices || []).map(ch => `
          <button
            data-next="${ch.next}"
            class="w-full text-left flex items-center gap-3 bg-dedsec-darker border border-dedsec-border
                   hover:border-neon-green hover:text-neon-green text-dedsec-text
                   font-mono text-sm px-5 py-4 rounded transition-all duration-200
                   hover:shadow-[0_0_12px_#00ff9f22] hover:translate-x-1 animate-fade-in"
          >
            <span class="text-neon-green/50 text-xs shrink-0">▸</span>
            <span>${ch.label}</span>
          </button>
        `).join('')}
      </div>
    `;
  }

  // Result node
  return `
    ${renderBreadcrumb()}
    <div class="border ${c.border} ${c.bg} rounded p-5 mb-6 animate-fade-in">
      <div class="flex items-center gap-3 mb-1">
        <span class="text-2xl">${node.icon || '▸'}</span>
        <h2 class="${c.text} font-mono text-lg font-bold m-0">${node.text}</h2>
      </div>
    </div>

    ${node.actions ? `
      <div class="card-neon mb-4 animate-fade-in">
        <div class="text-neon-green font-mono text-xs font-bold mb-3 uppercase tracking-widest">▸ Que faire maintenant</div>
        <ol class="space-y-2">
          ${node.actions.map((a, i) => `
            <li class="flex gap-3 text-sm text-dedsec-text">
              <span class="text-neon-green font-mono text-xs shrink-0 mt-0.5">${String(i+1).padStart(2,'0')}.</span>
              <span>${a}</span>
            </li>
          `).join('')}
        </ol>
      </div>
    ` : ''}

    ${node.rights ? `
      <div class="card-neon border-neon-cyan/30 mb-4 animate-fade-in">
        <div class="text-neon-cyan font-mono text-xs font-bold mb-3 uppercase tracking-widest">▸ Tes droits</div>
        <ul class="space-y-2">
          ${node.rights.map(r => `
            <li class="flex gap-2 text-sm text-dedsec-muted">
              <span class="text-neon-cyan/50 shrink-0">◇</span>
              <span>${r}</span>
            </li>
          `).join('')}
        </ul>
      </div>
    ` : ''}

    ${node.links?.length ? `
      <div class="flex flex-wrap gap-2 mb-6 animate-fade-in">
        ${node.links.map(l => `
          <a href="${l.href}" class="btn-neon text-xs no-underline">${l.label} →</a>
        `).join('')}
      </div>
    ` : ''}

    <div class="flex gap-3 mt-6 animate-fade-in">
      <button id="btn-restart"
        class="flex items-center gap-2 bg-dedsec-darker border border-neon-green/40 hover:border-neon-green
               text-neon-green font-mono text-xs px-4 py-2 rounded transition-all hover:shadow-[0_0_10px_#00ff9f22]">
        ↺ Recommencer
      </button>
      ${history.length > 1 ? `
        <button id="btn-back"
          class="flex items-center gap-2 bg-dedsec-darker border border-dedsec-border hover:border-dedsec-text
                 text-dedsec-muted hover:text-dedsec-text font-mono text-xs px-4 py-2 rounded transition-all">
          ← Retour
        </button>
      ` : ''}
    </div>
  `;
}

function render() {
  const container = document.getElementById('decision-tree')!;
  const current = history[history.length - 1];
  container.innerHTML = renderNode(current);

  // Choix
  container.querySelectorAll<HTMLButtonElement>('[data-next]').forEach(btn => {
    btn.addEventListener('click', () => {
      history.push(btn.dataset.next!);
      render();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });

  // Breadcrumb goto
  container.querySelectorAll<HTMLButtonElement>('[data-goto]').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = parseInt(btn.dataset.goto!);
      history = history.slice(0, idx + 1);
      render();
    });
  });

  // Restart
  document.getElementById('btn-restart')?.addEventListener('click', () => {
    history = ['root'];
    render();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // Back
  document.getElementById('btn-back')?.addEventListener('click', () => {
    if (history.length > 1) history.pop();
    render();
  });
}

render();
</script>
