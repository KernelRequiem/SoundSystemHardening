---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Que faire ?" description="Arbre de décision interactif - GAV, fouille, saisie, contrôle routier">
  <h1 class="mb-2">▸ QUE FAIRE SI...</h1>
  <p class="text-dedsec-muted text-sm mb-8 font-mono">Arbre de décision interactif - clique sur ta situation</p>

  <div id="decision-tree" class="max-w-2xl mx-auto"></div>
</Layout>

