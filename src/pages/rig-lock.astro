---
import Layout from '../layouts/Layout.astro';
---

<Layout title="RIG-LOCK" category="OUTILS">

  <!-- ═══════════════════════════════════════════════════════
       EN-TÊTE
  ═══════════════════════════════════════════════════════ -->
  <div class="rl-header">
    <div class="rl-badge">⊡ OUTIL OPÉRATIONNEL</div>
    <h1 class="rl-title">RIG-LOCK</h1>
    <p class="rl-subtitle">Générateur de manifeste de saisie horodaté et vérifiable</p>
    <div class="rl-local-notice">
      <span class="notice-icon">⚿</span>
      <span>Tout est généré <strong>localement dans votre navigateur</strong>. Aucune donnée n'est envoyée à un serveur.</span>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════
       FORMULAIRE
  ═══════════════════════════════════════════════════════ -->
  <form id="rigForm" autocomplete="off" novalidate>

    <!-- Section 1 : Informations sur la saisie -->
    <fieldset class="rl-section">
      <legend class="rl-legend"><span class="rl-num">01</span> Informations sur la saisie</legend>
      <div class="rl-grid-2">
        <div class="rl-field">
          <label for="f-date" class="rl-label">Date de la saisie <span class="req">*</span></label>
          <input id="f-date" name="date" type="date" class="rl-input" required />
        </div>
        <div class="rl-field">
          <label for="f-heure" class="rl-label">Heure approximative <span class="req">*</span></label>
          <input id="f-heure" name="heure" type="time" class="rl-input" required />
        </div>
        <div class="rl-field">
          <label for="f-lieu" class="rl-label">Lieu (Commune) <span class="req">*</span></label>
          <input id="f-lieu" name="lieu" type="text" placeholder="ex: Saint-Malo" class="rl-input" required />
        </div>
        <div class="rl-field">
          <label for="f-dept" class="rl-label">Département <span class="req">*</span></label>
          <input id="f-dept" name="dept" type="text" placeholder="ex: 35 - Ille-et-Vilaine" class="rl-input" required />
        </div>
      </div>
    </fieldset>

    <!-- Section 2 : Description de la saisie -->
    <fieldset class="rl-section">
      <legend class="rl-legend"><span class="rl-num">02</span> Description de la saisie</legend>

      <div class="rl-field">
        <label class="rl-label">Type de biens saisis <span class="req">*</span></label>
        <div id="typeGrid" class="rl-type-grid">
          {[
            { id:'son',     label:'Système son / enceintes' },
            { id:'ampli',   label:'Amplificateurs' },
            { id:'table',   label:'Tables de mixage' },
            { id:'cables',  label:'Câbles / connectiques' },
            { id:'gen',     label:'Groupe électrogène' },
            { id:'lumieres',label:'Éclairages / lasers' },
            { id:'vehicule',label:'Véhicule(s)' },
            { id:'autre',   label:'Autre' },
          ].map(t => (
            <label class="rl-check">
              <input type="checkbox" name="types" value={t.label} />
              <span>{t.label}</span>
            </label>
          ))}
        </div>
        <input id="f-types-autre" name="types_autre" type="text" placeholder="Précisez si Autre..." class="rl-input" style="margin-top:8px" />
      </div>

      <div class="rl-field" style="margin-top:14px">
        <label for="f-desc" class="rl-label">Description détaillée des biens <span class="req">*</span></label>
        <textarea id="f-desc" name="desc" rows="4" placeholder="Marques, modèles, numéros de série si connus, état au moment de la saisie..." class="rl-textarea" required></textarea>
      </div>

      <div class="rl-grid-2" style="margin-top:14px">
        <div class="rl-field">
          <label for="f-agents" class="rl-label">Nombre d'agents présents</label>
          <input id="f-agents" name="agents" type="number" min="0" placeholder="ex: 12" class="rl-input" />
        </div>
        <div class="rl-field">
          <label for="f-matricules" class="rl-label">Identités / matricules connus</label>
          <input id="f-matricules" name="matricules" type="text" placeholder="ex: 1734-5, brigade X..." class="rl-input" />
        </div>
      </div>
    </fieldset>

    <!-- Section 3 : Contexte -->
    <fieldset class="rl-section">
      <legend class="rl-legend"><span class="rl-num">03</span> Contexte <span class="rl-opt">(optionnel)</span></legend>

      <div class="rl-field">
        <label for="f-motif" class="rl-label">Motif / contexte invoqué par les forces de l'ordre</label>
        <textarea id="f-motif" name="motif" rows="3" placeholder="ex: Arrêté préfectoral du X, trouble à l'ordre public, absence de déclaration..." class="rl-textarea"></textarea>
      </div>

      <div class="rl-field" style="margin-top:14px">
        <label class="rl-label">Y a-t-il eu des violences ou dégradations ?</label>
        <div class="rl-radio-group">
          <label class="rl-radio"><input type="radio" name="violence" value="Non" checked /><span>Non</span></label>
          <label class="rl-radio"><input type="radio" name="violence" value="Oui" /><span>Oui</span></label>
          <label class="rl-radio"><input type="radio" name="violence" value="Non déterminé" /><span>Non déterminé</span></label>
        </div>
      </div>

      <div class="rl-field" style="margin-top:10px" id="violenceDetailWrap">
        <label for="f-violence-detail" class="rl-label">Précisions sur les violences / dégradations</label>
        <textarea id="f-violence-detail" name="violence_detail" rows="3" placeholder="Description des faits, blessures éventuelles, biens dégradés..." class="rl-textarea"></textarea>
      </div>
    </fieldset>

    <!-- Section 4 : Preuves et informations complémentaires -->
    <fieldset class="rl-section">
      <legend class="rl-legend"><span class="rl-num">04</span> Preuves et compléments <span class="rl-opt">(optionnel)</span></legend>

      <div class="rl-field">
        <label for="f-notes" class="rl-label">Notes et observations</label>
        <textarea id="f-notes" name="notes" rows="4" placeholder="Témoins présents, comportements notables, récit chronologique..." class="rl-textarea"></textarea>
      </div>

      <div class="rl-field" style="margin-top:14px">
        <label class="rl-label">Photos / pièces jointes</label>
        <div class="rl-upload-zone" id="uploadZone">
          <input type="file" id="f-photos" name="photos" accept="image/*" multiple class="rl-file-input" />
          <div class="rl-upload-label">
            <span class="upload-icon">⊕</span>
            <span>Sélectionner des photos</span>
            <span class="upload-sub">JPG, PNG, WEBP - stockées localement, non envoyées</span>
          </div>
        </div>
        <div id="photoPreview" class="photo-preview-grid" style="display:none"></div>
      </div>
    </fieldset>

    <!-- Erreur et bouton -->
    <p id="rlError" class="rl-error" style="display:none"></p>

    <div class="rl-actions">
      <button type="button" id="btnReset" class="rl-btn-secondary">↺ Réinitialiser</button>
      <button type="submit" id="btnGenerate" class="rl-btn-primary">
        <span id="btnLabel">⊡ GÉNÉRER LE MANIFESTE PDF</span>
      </button>
    </div>

  </form>

  <!-- ═══════════════════════════════════════════════════════
       AVERTISSEMENT LÉGAL
  ═══════════════════════════════════════════════════════ -->
  <div class="rl-legal">
    <p><strong>Usage :</strong> Ce document est un outil de documentation personnelle. Il ne remplace pas un constat d'huissier ou un dépôt de plainte officiel. Conservez-le avec vos preuves en vue d'un recours juridique.</p>
  </div>

  <!-- jsPDF via CDN -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js" is:inline></script>

  <script is:inline>
  (function () {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function genId() {
      var now = new Date();
      var pad = function(n){ return String(n).padStart(2,'0'); };
      var date = String(now.getFullYear()) + pad(now.getMonth()+1) + pad(now.getDate());
      var time = pad(now.getHours()) + pad(now.getMinutes()) + pad(now.getSeconds());
      var hex  = Math.floor(Math.random() * 0xFFFF).toString(16).toUpperCase().padStart(4,'0');
      return 'RL-' + date + '-' + time + '-' + hex;
    }

    function fmtDate(iso) {
      if (!iso) return '-';
      var d = new Date(iso);
      return d.toLocaleDateString('fr-FR', { day:'numeric', month:'long', year:'numeric' });
    }

    function val(id) {
      var el = document.getElementById(id);
      return el ? el.value.trim() : '';
    }

    // ── Gestion upload photos ─────────────────────────────────────────────────
    var photoFiles = [];

    document.getElementById('f-photos').addEventListener('change', function(e) {
      photoFiles = Array.from(e.target.files || []);
      var preview = document.getElementById('photoPreview');
      preview.innerHTML = '';
      if (photoFiles.length === 0) { preview.style.display = 'none'; return; }
      preview.style.display = 'grid';
      photoFiles.forEach(function(f, i) {
        var reader = new FileReader();
        reader.onload = function(ev) {
          var wrap = document.createElement('div');
          wrap.className = 'photo-thumb';
          wrap.innerHTML = '<img src="' + ev.target.result + '" alt="Photo ' + (i+1) + '" />' +
            '<span>' + f.name + '</span>';
          preview.appendChild(wrap);
        };
        reader.readAsDataURL(f);
      });
    });

    // ── Upload zone click ────────────────────────────────────────────────────
    document.getElementById('uploadZone').addEventListener('click', function(e) {
      if (e.target !== document.getElementById('f-photos')) {
        document.getElementById('f-photos').click();
      }
    });

    // ── Afficher/masquer détail violence ─────────────────────────────────────
    document.querySelectorAll('input[name="violence"]').forEach(function(r) {
      r.addEventListener('change', function() {
        document.getElementById('violenceDetailWrap').style.opacity = r.value === 'Oui' ? '1' : '0.4';
      });
    });

    // ── Reset ─────────────────────────────────────────────────────────────────
    document.getElementById('btnReset').addEventListener('click', function() {
      if (!confirm('Réinitialiser le formulaire ?')) return;
      document.getElementById('rigForm').reset();
      document.getElementById('photoPreview').style.display = 'none';
      document.getElementById('photoPreview').innerHTML = '';
      photoFiles = [];
      document.getElementById('rlError').style.display = 'none';
    });

    // ── Génération PDF ────────────────────────────────────────────────────────
    document.getElementById('rigForm').addEventListener('submit', async function(e) {
      e.preventDefault();

      // Validation champs requis
      var err = [];
      if (!val('f-date'))  err.push('Date de la saisie');
      if (!val('f-heure')) err.push('Heure de la saisie');
      if (!val('f-lieu'))  err.push('Lieu');
      if (!val('f-dept'))  err.push('Département');
      if (!val('f-desc'))  err.push('Description des biens');

      var typesChecked = Array.from(document.querySelectorAll('input[name="types"]:checked')).map(function(c){ return c.value; });
      if (typesChecked.length === 0) err.push('Type de biens saisis');

      if (err.length > 0) {
        var errEl = document.getElementById('rlError');
        errEl.textContent = 'Champs requis manquants : ' + err.join(', ') + '.';
        errEl.style.display = 'block';
        errEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }
      document.getElementById('rlError').style.display = 'none';

      var btn = document.getElementById('btnGenerate');
      var lbl = document.getElementById('btnLabel');
      btn.disabled = true;
      lbl.textContent = 'Génération en cours...';

      // Collecte des données
      var typesAutre = val('f-types-autre');
      var typesAll = typesChecked.concat(typesAutre ? [typesAutre] : []);
      var violence = document.querySelector('input[name="violence"]:checked');
      var violenceVal = violence ? violence.value : 'Non';
      var violenceDetail = val('f-violence-detail');

      var data = {
        id:             genId(),
        generatedAt:    new Date().toLocaleString('fr-FR'),
        date:           fmtDate(val('f-date')),
        heure:          val('f-heure') || '-',
        lieu:           val('f-lieu'),
        dept:           val('f-dept'),
        types:          typesAll.join(', '),
        desc:           val('f-desc'),
        agents:         val('f-agents')     || 'Non renseigné',
        matricules:     val('f-matricules') || 'Non renseigné',
        motif:          val('f-motif')      || 'Non renseigné',
        violence:       violenceVal,
        violenceDetail: violenceVal === 'Oui' ? (violenceDetail || 'Non précisé') : null,
        notes:          val('f-notes') || null,
        photosCount:    photoFiles.length,
      };

      // Lecture async des photos en base64
      var photoB64 = [];
      if (photoFiles.length > 0) {
        var readings = photoFiles.slice(0, 4).map(function(f) {
          return new Promise(function(res, rej) {
            var r = new FileReader();
            r.onload = function(ev) { res(ev.target.result); };
            r.onerror = rej;
            r.readAsDataURL(f);
          });
        });
        try { photoB64 = await Promise.all(readings); } catch(_) { photoB64 = []; }
      }

      buildPDF(data, photoB64);

      btn.disabled = false;
      lbl.textContent = '⊡ GÉNÉRER LE MANIFESTE PDF';
    });

    // ── Construction du PDF ───────────────────────────────────────────────────
    function buildPDF(d, photos) {
      var jsPDF = window.jspdf.jsPDF;
      var doc = new jsPDF({ orientation:'p', unit:'mm', format:'a4' });

      var PAGE_W  = 210;
      var PAGE_H  = 297;
      var MARGIN  = 18;
      var CONTENT = PAGE_W - MARGIN * 2;
      var y = MARGIN;

      // Couleurs
      var C_BLACK   = [10, 10, 15];
      var C_WHITE   = [255, 255, 255];
      var C_MUTED   = [120, 120, 140];
      var C_BORDER  = [210, 210, 220];
      var C_SECTION = [240, 240, 248];

      function checkPage(needed) {
        if (y + needed > PAGE_H - MARGIN) {
          doc.addPage();
          y = MARGIN;
          drawHeader(true);
          y += 8;
        }
      }

      function drawHeader(continuation) {
        // Bandeau noir en-tête
        doc.setFillColor(10, 10, 15);
        doc.rect(0, 0, PAGE_W, 22, 'F');
        doc.setFont('Courier', 'bold');
        doc.setFontSize(9);
        doc.setTextColor(...C_WHITE);
        doc.text('SOUNDSYSTEMHARDENING.FR', MARGIN, 10);
        doc.setFont('Courier', 'normal');
        doc.setFontSize(7);
        doc.setTextColor(180, 180, 200);
        doc.text(continuation ? 'MANIFESTE DE SAISIE - SUITE' : 'MANIFESTE DE SAISIE - RIG-LOCK', PAGE_W/2, 10, { align:'center' });
        doc.text('ID : ' + d.id, PAGE_W - MARGIN, 10, { align:'right' });
        doc.text('CC BY-SA 4.0', MARGIN, 17);
        doc.text('DOCUMENT GÉNÉRÉ LOCALEMENT', PAGE_W/2, 17, { align:'center' });
        doc.text('Page ' + doc.getCurrentPageInfo().pageNumber, PAGE_W - MARGIN, 17, { align:'right' });
      }

      function drawSectionTitle(title) {
        checkPage(14);
        doc.setFillColor(...C_SECTION);
        doc.rect(MARGIN, y, CONTENT, 8, 'F');
        doc.setDrawColor(...C_BORDER);
        doc.rect(MARGIN, y, CONTENT, 8, 'S');
        doc.setFont('Courier', 'bold');
        doc.setFontSize(8.5);
        doc.setTextColor(...C_BLACK);
        doc.text(title.toUpperCase(), MARGIN + 4, y + 5.5);
        y += 12;
      }

      function drawField(label, value, multiline) {
        if (!value) return;
        var lines = multiline
          ? doc.splitTextToSize(value, CONTENT - 6)
          : [value];
        var height = Math.max(10, lines.length * 5 + 4);
        checkPage(height + 4);

        // Label
        doc.setFont('Courier', 'bold');
        doc.setFontSize(7.5);
        doc.setTextColor(...C_MUTED);
        doc.text(label.toUpperCase(), MARGIN, y + 4);
        y += 5;

        // Valeur
        doc.setFillColor(252, 252, 255);
        doc.setDrawColor(...C_BORDER);
        doc.rect(MARGIN, y, CONTENT, height, 'FD');
        doc.setFont('Courier', 'normal');
        doc.setFontSize(9);
        doc.setTextColor(...C_BLACK);
        lines.forEach(function(line, i) {
          doc.text(line, MARGIN + 3, y + 5 + i * 5);
        });
        y += height + 3;
      }

      function drawRow(label, value) {
        checkPage(8);
        doc.setFont('Courier', 'bold');
        doc.setFontSize(7.5);
        doc.setTextColor(...C_MUTED);
        doc.text(label.toUpperCase(), MARGIN, y + 4);
        doc.setFont('Courier', 'normal');
        doc.setFontSize(9);
        doc.setTextColor(...C_BLACK);
        doc.text(value || '-', MARGIN + 55, y + 4);
        y += 7;
      }

      // ── En-tête ──────────────────────────────────────────────────────────
      drawHeader(false);
      y = 30;

      // Titre principal
      doc.setFont('Courier', 'bold');
      doc.setFontSize(18);
      doc.setTextColor(...C_BLACK);
      doc.text('MANIFESTE DE SAISIE', PAGE_W/2, y, { align:'center' });
      y += 7;

      doc.setFont('Courier', 'normal');
      doc.setFontSize(8);
      doc.setTextColor(...C_MUTED);
      doc.text('Généré le ' + d.generatedAt + ' - Outil RIG-LOCK (SoundSystemHardening.fr)', PAGE_W/2, y, { align:'center' });
      y += 5;
      doc.text('Ce document est généré localement par le navigateur. Aucune donnée transmise.', PAGE_W/2, y, { align:'center' });
      y += 10;

      // Ligne séparatrice
      doc.setDrawColor(...C_BORDER);
      doc.line(MARGIN, y, PAGE_W - MARGIN, y);
      y += 8;

      // Bloc ID / hash
      doc.setFillColor(10, 10, 15);
      doc.rect(MARGIN, y, CONTENT, 12, 'F');
      doc.setFont('Courier', 'bold');
      doc.setFontSize(8);
      doc.setTextColor(...C_WHITE);
      doc.text('IDENTIFIANT DOCUMENT', MARGIN + 4, y + 5);
      doc.setFont('Courier', 'normal');
      doc.setFontSize(11);
      doc.text(d.id, MARGIN + 4, y + 10.5);
      y += 18;

      // ── Section 01 ───────────────────────────────────────────────────────
      drawSectionTitle('01 - Informations sur la saisie');
      drawRow('Date', d.date);
      drawRow('Heure', d.heure);
      drawRow('Lieu', d.lieu);
      drawRow('Département', d.dept);
      y += 4;

      // ── Section 02 ───────────────────────────────────────────────────────
      drawSectionTitle('02 - Description de la saisie');
      drawField('Types de biens saisis', d.types, false);
      drawField('Description détaillée', d.desc, true);
      drawRow("Nombre d'agents présents", d.agents);
      drawRow('Identités / matricules', d.matricules);
      y += 4;

      // ── Section 03 ───────────────────────────────────────────────────────
      drawSectionTitle('03 - Contexte de la saisie');
      drawField('Motif invoqué', d.motif, true);
      drawRow('Violences / dégradations', d.violence);
      if (d.violenceDetail) {
        drawField('Précisions', d.violenceDetail, true);
      }
      y += 4;

      // ── Section 04 ───────────────────────────────────────────────────────
      drawSectionTitle('04 - Preuves et observations');
      if (d.notes) {
        drawField('Notes et observations', d.notes, true);
      } else {
        drawRow('Notes', 'Aucune');
      }
      drawRow('Photos attachées', d.photosCount > 0 ? d.photosCount + ' photo(s) (voir pages suivantes)' : 'Aucune');
      y += 4;

      // ── Photos ───────────────────────────────────────────────────────────
      if (photos.length > 0) {
        photos.forEach(function(b64, i) {
          doc.addPage();
          y = MARGIN;
          drawHeader(true);
          y = 32;

          doc.setFont('Courier', 'bold');
          doc.setFontSize(9);
          doc.setTextColor(...C_MUTED);
          doc.text('PIÈCE JOINTE ' + (i+1) + ' / ' + photos.length, PAGE_W/2, y, { align:'center' });
          y += 6;

          var imgW = CONTENT;
          var imgH = 150;
          try {
            var format = b64.indexOf('image/png') !== -1 ? 'PNG' : 'JPEG';
            doc.addImage(b64, format, MARGIN, y, imgW, imgH, '', 'MEDIUM');
          } catch(_) {
            doc.setFontSize(8);
            doc.setTextColor(200, 50, 50);
            doc.text('Erreur : impossible d\'ajouter cette image.', MARGIN, y + 10);
          }
          y += imgH + 10;

          drawRow('Document ID', d.id);
        });
      }

      // ── Pied de page sur chaque page ─────────────────────────────────────
      var totalPages = doc.getNumberOfPages();
      for (var p = 1; p <= totalPages; p++) {
        doc.setPage(p);
        doc.setDrawColor(...C_BORDER);
        doc.line(MARGIN, PAGE_H - 14, PAGE_W - MARGIN, PAGE_H - 14);
        doc.setFont('Courier', 'normal');
        doc.setFontSize(6.5);
        doc.setTextColor(...C_MUTED);
        doc.text('SoundSystemHardening.fr - RIG-LOCK // CC BY-SA 4.0 // Document informatif, non contractuel.', PAGE_W/2, PAGE_H - 10, { align:'center' });
        doc.text('ID : ' + d.id + ' // Page ' + p + ' / ' + totalPages, PAGE_W/2, PAGE_H - 6, { align:'center' });
      }

      // ── Export ────────────────────────────────────────────────────────────
      var filename = 'RIG-LOCK_' + d.id + '.pdf';
      doc.save(filename);
    }

  })();
  </script>

</Layout>

<style is:global>
  /* ── Variables locales ───────────────────────────────────── */
  .rl-header { margin-bottom: 28px; }
  .rl-badge { display: inline-block; font-size: 9px; letter-spacing: 2px; color: #00ff9f; border: 1px solid rgba(0,255,159,0.3); padding: 3px 10px; margin-bottom: 10px; }
  .rl-title { font-size: 28px !important; color: #00ff9f !important; letter-spacing: 3px; margin: 0 0 6px !important; padding: 0 !important; border: none !important; }
  .rl-subtitle { font-size: 12px; color: #7a7a8a; letter-spacing: 1px; margin-bottom: 14px; font-family: 'JetBrains Mono', monospace; }
  .rl-local-notice { display: flex; align-items: flex-start; gap: 10px; background: rgba(0,255,159,0.05); border: 1px solid rgba(0,255,159,0.2); padding: 10px 14px; font-size: 11px; color: #c8c8d8; line-height: 1.6; font-family: 'JetBrains Mono', monospace; }
  .notice-icon { color: #00ff9f; font-size: 16px; flex-shrink: 0; line-height: 1.4; }
  .rl-local-notice strong { color: #00ff9f; }

  /* ── Sections ────────────────────────────────────────────── */
  .rl-section { border: 1px solid #1a1f2e; padding: 20px; margin-bottom: 18px; background: rgba(8,8,12,0.6); }
  .rl-legend { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #00ff9f; letter-spacing: 1.5px; padding: 0 8px; text-transform: uppercase; }
  .rl-num { font-size: 9px; color: rgba(0,255,159,0.5); margin-right: 6px; }
  .rl-opt { font-size: 9px; color: #3a3a4a; font-weight: normal; letter-spacing: 0; margin-left: 6px; }

  /* ── Grille et champs ────────────────────────────────────── */
  .rl-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .rl-field { display: flex; flex-direction: column; gap: 6px; }
  .rl-label { font-family: 'JetBrains Mono', monospace; font-size: 9px; color: #5a6472; letter-spacing: 1.5px; text-transform: uppercase; }
  .req { color: #ff2e4d; }
  .rl-input, .rl-textarea {
    background: #05060a; border: 1px solid #1a1f2e; color: #e8e8f0;
