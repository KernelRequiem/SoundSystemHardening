---
import '../styles/global.css';
import SpeedInsights from "@vercel/speed-insights/astro"
import TableOfContents from '../components/TableOfContents.astro';

interface Props {
  title: string;
  description?: string;
  category?: string;
  categoryHref?: string;
  ogImage?: string;
}

const { title, description, category, categoryHref, ogImage } = Astro.props;
const currentPath = Astro.url.pathname;

const siteUrl = 'https://soundsystemhardening.fr';
const defaultDescription = 'Wiki collectif : droits, opsec et résistance pour le mouvement free party. Loi RIPOST, sécurité numérique, stratégies juridiques.';
const resolvedDescription = description || defaultDescription;
const resolvedImage = ogImage || `${siteUrl}/SoundSystemHardening-logo.png`;
const resolvedTitle = title === 'Home' ? 'SoundSystemHardening' : `${title} | SoundSystemHardening`;

const sidebarIcons: Record<string, string> = {
  home:      `<path d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" stroke-linecap="round" stroke-linejoin="round"/>`,
  scale:     `<path d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0 0 12 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 0 1-2.031.352 5.988 5.988 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971Zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 0 1-2.031.352 5.989 5.989 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971Z" stroke-linecap="round" stroke-linejoin="round"/>`,
  shield:    `<path d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" stroke-linecap="round" stroke-linejoin="round"/>`,
  crosshair: `<path d="M12 3v3m0 12v3M3 12h3m12 0h3m-4.222-6.778-2.121 2.121M9.343 14.657l-2.121 2.121m0-9.9 2.121 2.121m5.314 5.314 2.121 2.121M12 8.25a3.75 3.75 0 1 0 0 7.5 3.75 3.75 0 0 0 0-7.5Z" stroke-linecap="round" stroke-linejoin="round"/>`,
  clock:     `<path d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" stroke-linecap="round" stroke-linejoin="round"/>`,
  megaphone: `<path d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 1 1 0-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 0 1-1.44-4.282m3.102.069a18.03 18.03 0 0 1-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 0 1 8.835 2.535M10.34 6.66a23.847 23.847 0 0 1 8.835-2.535m0 0A23.74 23.74 0 0 1 18.795 3m.38 1.125a23.91 23.91 0 0 1 1.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 0 0 1.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 0 1 0 3.46" stroke-linecap="round" stroke-linejoin="round"/>`,
  terminal:  `<path d="m6.75 7.5 3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0 0 21 18V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v12a2.25 2.25 0 0 0 2.25 2.25Z" stroke-linecap="round" stroke-linejoin="round"/>`,
  eye:       `<path d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" stroke-linecap="round" stroke-linejoin="round"/><path d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" stroke-linecap="round" stroke-linejoin="round"/>`,
  radio:     `<path d="M3.75 7.5l16.5-4.125M12 6.75c-2.708 0-5.363.224-7.948.655C2.566 7.685 1.5 9.048 1.5 10.61v4.765c0 1.562 1.067 2.926 2.552 3.207C6.637 19.026 9.292 19.25 12 19.25s5.363-.224 7.948-.655c1.485-.281 2.552-1.645 2.552-3.207v-4.765c0-1.562-1.067-2.925-2.552-3.206A48.97 48.97 0 0 0 12 6.75Zm-1.5 6a1.5 1.5 0 1 0 3 0 1.5 1.5 0 0 0-3 0Z" stroke-linecap="round" stroke-linejoin="round"/>`,
  lock:      `<path d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" stroke-linecap="round" stroke-linejoin="round"/>`,
  funnel:    `<path d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 0 1-.659 1.591l-5.432 5.432a2.25 2.25 0 0 0-.659 1.591v2.927a2.25 2.25 0 0 1-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 0 0-.659-1.591L3.659 7.409A2.25 2.25 0 0 1 3 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0 1 12 3Z" stroke-linecap="round" stroke-linejoin="round"/>`,
};

const navigation = [
  { section: 'DROITS & LIBERTÉS', icon: 'scale', links: [
    { href: '/wiki/arsenal-legislatif', label: 'Arsenal législatif', emoji: '📜' },
    { href: '/wiki/jurisprudence', label: 'Jurisprudence', emoji: '⚖️' },
    { href: '/wiki/recours-juridiques', label: 'Recours juridiques', emoji: '🛡️' },
    { href: '/wiki/repression', label: 'Répression', emoji: '⚠️' },
  ]},
  { section: 'CONTRE RIPOST', icon: 'shield', links: [
    { href: '/wiki/Strategie-contre-ripost', label: 'Stratégie contre RIPOST', emoji: '🛡️' },
    { href: '/wiki/Contestation', label: 'Contester les amendes', emoji: '📋' },
  ]},
  { section: 'STRATÉGIE', icon: 'crosshair', links: [
    { href: '/wiki/Stratégie-résistance', label: "Vue d'ensemble", emoji: '◇' },
    { href: '/wiki/Juridique', label: 'Axe juridique', emoji: '⚖️' },
    { href: '/wiki/Politique', label: 'Axe politique', emoji: '📢' },
    { href: '/wiki/Sanitaire', label: 'Axe sanitaire', emoji: '🏥' },
    { href: '/wiki/Organisationnel', label: 'Axe organisationnel', emoji: '🔧' },
    { href: '/wiki/Culturel', label: 'Axe culturel', emoji: '🎵' },
    { href: '/wiki/Coalitions', label: 'Coalitions', emoji: '🤝' },
  ]},
  { section: 'HISTOIRE & CULTURE', icon: 'clock', links: [
    { href: "/wiki/L'esprit-des-teufeurs", label: "L'esprit des teufeurs", emoji: '✊' },
    { href: '/wiki/Histoire-&-Culture', label: "Vue d'ensemble", emoji: '◇' },
    { href: '/wiki/Chronologie', label: 'Chronologie 1988-2026', emoji: '📅' },
    { href: '/wiki/Sound-System', label: 'Sound Systems', emoji: '🔊' },
    { href: '/wiki/Incidents-répressifs', label: 'Incidents répressifs', emoji: '⚠️' },
    { href: '/wiki/Patrimoine-culturel', label: 'Patrimoine culturel', emoji: '🎨' },
  ]},
  { section: 'MOBILISATION', icon: 'megaphone', links: [
    { href: '/wiki/Mobilisation', label: "Vue d'ensemble", emoji: '◇' },
    { href: '/wiki/Templates-Recours', label: 'Templates de recours', emoji: '📝' },
    { href: '/wiki/Contacts-Allies', label: 'Contacts et alliés', emoji: '📞' },
    { href: '/wiki/Argumentaires', label: 'Argumentaires', emoji: '💬' },
  ]},
  { section: 'MODUS OPERANDI', icon: 'terminal', links: [
    { href: '/wiki/Modus-Operandi', label: "Vue d'ensemble", emoji: '◇' },
    { href: '', label: '── Zones grises ──', emoji: '' },
    { href: '/wiki/ZAD-Pourquoi-État-Evite', label: 'ZAD', emoji: '🌳' },
    { href: '/wiki/Propriete-Privee-Fermee', label: 'Propriété privée', emoji: '🔒' },
    { href: '/wiki/Terrains-Abandonnes', label: 'Terrains abandonnés', emoji: '🏚️' },
    { href: '/wiki/Espaces-Semi-Publics', label: 'Espaces semi-publics', emoji: '🏛️' },
    { href: '/wiki/Zones-Limitrophes', label: 'Zones limitrophes', emoji: '↔️' },
    { href: '', label: '── Failles légales ──', emoji: '' },
    { href: '/wiki/Definition-Ambigue-Organisateur', label: 'Définition organisateur', emoji: '❓' },
    { href: '/wiki/Seuil-250-500-Personnes', label: 'Seuil 250-500', emoji: '👥' },
    { href: '/wiki/Rassemblement-vs-Manifestation', label: 'Rassemblement vs Manif', emoji: '⚖️' },
    { href: '/wiki/Declaration-Preuve-Legitimite', label: 'Déclaration légitimité', emoji: '📋' },
    { href: '/wiki/Prescription-et-Delais', label: 'Prescription', emoji: '⏰' },
    { href: '', label: '── Failles opéra. ──', emoji: '' },
    { href: '/wiki/Manque-de-Ressources', label: 'Manque de ressources', emoji: '📉' },
    { href: '/wiki/Coordination-Defaillante', label: 'Coordination défaillante', emoji: '⚙️' },
    { href: '', label: '── Contournement ──', emoji: '' },
    { href: '/wiki/Camouflage-Evenement', label: 'Camouflage', emoji: '🎭' },
    { href: '/wiki/Fragmentation-Geographique', label: 'Fragmentation', emoji: '🗺️' },
    { href: '/wiki/Coordination-Decentralisee', label: 'Coordination décentralisée', emoji: '🔗' },
    { href: '/wiki/Documentation-Preemptive', label: 'Documentation préemptive', emoji: '📸' },
  ]},
  { section: 'VEILLE', icon: 'eye', links: [
    { href: "/wiki/Vue-d'ensemble-veille", label: "Vue d'ensemble", emoji: '◇' },
    { href: '/wiki/Lois-En-Cours', label: 'Lois en cours', emoji: '📜' },
    { href: '/wiki/Actualites-Repressions', label: 'Actualités répression', emoji: '📰' },
    { href: '/wiki/Sources-Fiables', label: 'Sources fiables', emoji: '📚' },
    { href: '/wiki/Changelog', label: 'Changelog', emoji: '📝' },
  ]},
  { section: 'MÉDIAS & INFOS', icon: 'radio', links: [
    { href: '/wiki/Medias-Propriete', label: 'Médias & Propriété', emoji: '💰' },
  ]},
  { section: 'CYBER-OPSEC', icon: 'lock', links: [
    { href: '/wiki/Sécurite-Numerique', label: 'Sécurité numérique', emoji: '🛡️' },
    { href: '/wiki/Sécurité-des-communications', label: 'Communications sécurisées', emoji: '💬' },
    { href: '/wiki/reseau-anonymisation', label: 'VPN & Tor  -  réseau anonyme', emoji: '🕸️' },
    { href: '/wiki/darknet-pgp-anonymat', label: 'Darknet, Tor, VPN & PGP', emoji: '🔑' },
    { href: '/wiki/messagerie-chiffree', label: 'Messagerie chiffrée', emoji: '📨' },
    { href: '/infocrypt', label: 'InfoCrypt — Chiffrer une fiche', emoji: '🔐' },
  ]},
];
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{resolvedTitle}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "SoundSystemHardening",
      "url": "https://soundsystemhardening.fr",
      "logo": "https://soundsystemhardening.fr/SoundSystemHardening-logo.png",
      "description": "Wiki collectif : droits, opsec, résistance pour le mouvement free party"
    }
    </script>
    <meta name="description" content={resolvedDescription} />
    <link rel="canonical" href={`${siteUrl}${currentPath}`} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}${currentPath}`} />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:image" content={resolvedImage} />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:site_name" content="SoundSystemHardening" />
    <meta property="og:locale" content="fr_FR" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={resolvedImage} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#00ff9f" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="SSHardening" />
    <style>
      /* Animation pin carte dans la topbar */
      .carte-pin-idle {
        display: inline-flex;
        animation: pin-pulse 2.5s ease-in-out infinite;
        transform-origin: center bottom;
      }
      @keyframes pin-pulse {
        0%, 100% { transform: translateY(0) scale(1); opacity: 1; }
        50%       { transform: translateY(-2px) scale(1.15); opacity: .7; }
      }
      .carte-pin-active {
        display: inline-flex;
        filter: drop-shadow(0 0 4px #00ff9f);
        animation: pin-glow 1.2s ease-in-out infinite alternate;
      }
      @keyframes pin-glow {
        from { filter: drop-shadow(0 0 2px #00ff9f); }
        to   { filter: drop-shadow(0 0 8px #00ff9f) drop-shadow(0 0 14px #00ff9f66); }
      }
    </style>
  </head>
  <body>
    <SpeedInsights />
    <div id="progress-bar" class="fixed top-0 left-0 h-[2px] z-[9999] pointer-events-none" style="width: 0%; background: linear-gradient(90deg, #00ff9f, #00d9ff); box-shadow: 0 0 8px #00ff9f;"></div>
    <button id="menu-toggle" class="fixed top-4 left-4 z-50 flex bg-dedsec-darker border border-neon-green p-2 rounded text-neon-green hover:bg-neon-green/10 transition-all" aria-label="Toggle menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
    <div class="flex min-h-screen">
      <aside id="sidebar" class="fixed top-0 left-0 h-screen w-72 bg-dedsec-darker border-r border-dedsec-border overflow-y-auto transition-transform duration-300 z-40 -translate-x-full flex flex-col">

        <!-- HEADER : logo centré + titre -->
        <div class="shrink-0 border-b border-dedsec-border">
          <a href="/" class="flex flex-col items-center pt-4 pb-4 px-4 no-underline group">
            <img
              src="/SoundSystemHardeninglogo.png"
              alt="SoundSystem Hardening"
              class="w-full object-contain no-border mb-3"
              style="filter: drop-shadow(0 0 12px rgba(0,255,159,0.2));"
            />
            <div class="text-center">
              <div class="font-display font-bold text-neon-green text-sm leading-tight tracking-widest uppercase">
                SoundSystem
              </div>
              <div class="font-display font-bold text-dedsec-text text-sm leading-tight tracking-widest uppercase">
                Hardening
              </div>
              <div class="text-[9px] text-dedsec-muted font-mono uppercase tracking-[0.2em] mt-1.5 opacity-60">
                ▸ resistance toolkit
              </div>
            </div>
          </a>

          <!-- Barre de recherche -->
          <div class="px-3 pb-3">
            <a href="/search" class="flex items-center gap-2 bg-dedsec-black/60 border border-dedsec-border hover:border-neon-green/40 px-3 py-2 text-dedsec-muted hover:text-neon-green transition-all no-underline group">
              <span class="text-neon-green/40 font-mono text-xs group-hover:text-neon-green/70">⌕</span>
              <span class="font-mono text-xs flex-1 text-dedsec-muted/60">rechercher...</span>
              <kbd class="font-mono text-[9px] border border-dedsec-border/60 px-1 py-0.5 text-dedsec-muted/40">/</kbd>
            </a>
          </div>

          <!-- Actions rapides -->
          <div class="px-3 pb-4 grid grid-cols-2 gap-2">
            <a href="/urgence" class="sidebar-quick-crit no-underline"
               style={currentPath === '/urgence' ? 'border-color:rgba(255,68,68,0.7);color:rgba(255,68,68,1);background:rgba(255,68,68,0.08);' : ''}>
              <span>▲</span> URGENCE
            </a>
            <a href="/contribuer" class="sidebar-quick no-underline">
              <span>✎</span> CONTRIB.
            </a>
          </div>
        </div>

        <!-- NAV -->
        <nav class="flex-1 overflow-y-auto py-2 pb-20">
          {navigation.map((section) => (
            <div class="sidebar-accordion">
              <div class="sidebar-section-title">
                <span class="sidebar-sec-inner">
                  <svg class="sidebar-sec-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                    <Fragment set:html={sidebarIcons[section.icon] ?? ''} />
                  </svg>
                  <span class="sidebar-sec-text">{section.section}</span>
                </span>
                <svg class="chevron-svg" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="sidebar-section-links">
                {section.links.map((link) => (
                  link.href === '' ? (
                    <div class="sidebar-sublabel">{link.label.replace(/──\s*/g, '').replace(/\s*──/g, '')}</div>
                  ) : (
                    <a href={link.href} class={link.href === currentPath ? 'sidebar-link active' : 'sidebar-link'}>
                      {link.label}
                    </a>
                  )
                ))}
              </div>
            </div>
          ))}
        </nav>

        <!-- FOOTER -->
        <div class="shrink-0 border-t border-dedsec-border px-4 py-3">
          <div class="flex items-center justify-between text-[9px] font-mono text-dedsec-muted/50 uppercase tracking-widest">
            <span>v1.0.0 · CC BY-SA 4.0</span>
            <a href="https://github.com/KernelRequiem/SoundSystemHardening" target="_blank" class="text-neon-green/40 hover:text-neon-green transition-colors no-underline">GH</a>
          </div>
        </div>

      </aside>
      <div id="overlay" class="fixed inset-0 bg-black/80 z-30 hidden"></div>
      <main class="flex-1 min-w-0">
        <div class="sticky top-0 z-20 border-b border-dedsec-border relative" style="background: linear-gradient(180deg, rgba(8,8,12,0.98) 0%, rgba(10,10,15,0.95) 100%); backdrop-filter: blur(12px);">
          <!-- Accent latéral gauche -->
          <div class="absolute left-0 top-0 bottom-0 w-[2px]" style="background: linear-gradient(180deg, rgba(0,255,159,0.5) 0%, rgba(0,255,159,0.05) 100%);"></div>

          <!-- Ligne 1 : breadcrumb + contrôles -->
          <div class="flex items-center h-11 pl-16 pr-0 gap-3">
            <!-- Ancre home -->
            <a href="/" class="flex-shrink-0 no-underline font-mono text-[11px] text-neon-green/70 hover:text-neon-green transition-colors" style="text-shadow: 0 0 8px rgba(0,255,159,0.4)">◆</a>
            <div class="w-px h-4 bg-dedsec-border/60 flex-shrink-0"></div>
            <!-- Breadcrumb -->
            <nav class="flex items-center gap-1.5 font-mono text-[11px] flex-1 min-w-0">
              {categoryHref
                ? <a href={categoryHref} class="text-dedsec-muted/60 hover:text-neon-green transition-colors no-underline flex-shrink-0 tracking-wider">{category || 'WIKI'}</a>
                : <span class="text-dedsec-muted/60 tracking-wider flex-shrink-0">{category || 'WIKI'}</span>
              }
              <span class="text-dedsec-border/50 flex-shrink-0">›</span>
              <span class="text-dedsec-text/50 truncate tracking-wide">{title}</span>
            </nav>
            <!-- Contrôles droite -->
            <div class="flex items-center flex-shrink-0 self-stretch">
              <a href="/search" class="hidden md:flex items-center gap-1.5 self-stretch px-4 font-mono text-[10px] tracking-widest text-dedsec-muted/50 hover:text-neon-green hover:bg-neon-green/5 transition-all no-underline border-l border-dedsec-border">
                <span class="text-base leading-none">⌕</span>
              </a>
              <button id="theme-toggle" class="hidden md:flex items-center justify-center self-stretch w-10 text-dedsec-muted/50 hover:text-neon-green hover:bg-neon-green/5 transition-all border-l border-dedsec-border">
                <span id="theme-icon" class="text-sm">🌙</span>
              </button>
