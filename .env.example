# ── SMTP Infomaniak ───────────────────────────────────────────────────────────
# Paramètres disponibles dans : Infomaniak Manager → Mail → Paramètres SMTP

SMTP_HOST=mail.infomaniak.com
SMTP_PORT=587
# 587 = STARTTLS (recommandé) | 465 = SSL/TLS

SMTP_USER=contact@soundsystemhardening.fr
SMTP_PASS=votre_mot_de_passe_mail

# Adresse de destination des messages reçus
CONTACT_TO=contact@soundsystemhardening.fr
