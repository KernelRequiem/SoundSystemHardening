# ── Zone opérationnelle — Authentification interne (/terrain) ─────────────────
# Générer ADMIN_SECRET :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
#
# Générer un hash de mot de passe (après avoir défini ADMIN_SECRET) :
#   ADMIN_SECRET=<valeur> node scripts/gen-admin-hash.mjs "MonMotDePasse"
#
# Format ADMIN_CREDS : "email:pbkdf2_hash:role;email2:pbkdf2_hash2:role2"
# Rôles disponibles : admin | moderator

ADMIN_SECRET=generer_avec_la_commande_ci_dessus_48_bytes_hex
ADMIN_CREDS=admin@soundsystemhardening.fr:pbkdf2_hash_ici:admin;tech@soundsystemhardening.fr:pbkdf2_hash_ici:moderator

# ── SMTP Infomaniak ───────────────────────────────────────────────────────────
# Paramètres disponibles dans : Infomaniak Manager → Mail → Paramètres SMTP

SMTP_HOST=mail.infomaniak.com
SMTP_PORT=587
# 587 = STARTTLS (recommandé) | 465 = SSL/TLS

SMTP_USER=contact@soundsystemhardening.fr
SMTP_PASS=votre_mot_de_passe_mail

# Adresse de destination des messages reçus
CONTACT_TO=contact@soundsystemhardening.fr

# ── HardeningCore — Import des Issues GitHub dans la modération ───────────────
# Optionnel. Permet au module de modération de tirer les Issues ouvertes du repo
# dans la file de modération unifiée (bouton « Importer les issues GitHub »).
# GITHUB_REPO : "owner/repo". GITHUB_TOKEN (fine-grained, lecture Issues) augmente
# le quota d'appels et autorise les repos privés. Jamais exposé au client.
GITHUB_REPO=KernelRequiem/SoundSystemHardening
# GITHUB_TOKEN=github_pat_xxx

# ── HardeningCore — Données mutables d'administration ────────────────────────
# Le module écrit dans ./data/admin (modération, validation légale, historique)
# et dans src/content/wiki (pages) + src/data/incidents.json (carte).
# EN PRODUCTION CONTENEURISÉE : monter un volume persistant sur ./data/admin,
# src/content/wiki et src/data, sinon les écritures sont perdues au redémarrage.
